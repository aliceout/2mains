---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banderole from '../components/Banderole.astro';
import { getSiteSettings } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
};

const settings = await getSiteSettings();

const {
  title,
  description = settings.mission,
  image = '/brand/logo.svg',
  noindex = false,
} = Astro.props;

const fullTitle = title
  ? `${title} — ${settings.nom_asso}`
  : `${settings.nom_asso} — ${settings.accroche_globale}`;
const canonical = new URL(Astro.url.pathname, settings.url).toString();

const bandero = settings.banderole_urgence;
const showBandero = bandero?.active && bandero.message;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, settings.url).toString()} />
    <meta property="og:locale" content="fr_FR" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload fonts -->
    <link
      rel="preload"
      href="/fonts/nunito-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/nunito-bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#contenu" class="skip-link">Aller au contenu principal</a>
    {showBandero && <Banderole message={bandero!.message!} couleur={bandero!.couleur} />}
    <Header settings={settings} />
    <main id="contenu" class="flex-1">
      <slot />
    </main>
    <Footer settings={settings} />
  </body>
</html>
