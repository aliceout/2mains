---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banderole from '../components/Banderole.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ShareButton from '../components/ShareButton.astro';
import { getSiteSettings } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  ogSlug?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const settings = await getSiteSettings();

const {
  title,
  description = settings.mission,
  image,
  ogSlug,
  noindex = false,
  jsonLd,
} = Astro.props;

// OG image : par page si ogSlug fourni (image PNG 1200x630 générée par
// /og/[slug].png.ts), sinon image statique explicite, sinon logo.
const ogImagePath = image ?? (ogSlug ? `/og/${ogSlug}.png` : '/brand/logo.svg');

const fullTitle = title
  ? `${title} — ${settings.nom_asso}`
  : `${settings.nom_asso} — ${settings.accroche_globale}`;
const canonical = new URL(Astro.url.pathname, settings.url).toString();

const bandero = settings.banderole_urgence;
const showBandero = bandero?.active && bandero.message;

// Adresse affichée en 1 ligne dans settings ; on l'éclate pour le schema.org.
// Format attendu : "Tiers-lieu La Médiane, 255 rue de Créqui, 69003 Lyon"
const addressParts = settings.adresse.split(',').map((p) => p.trim());
const lastPart = addressParts.at(-1) ?? '';
const postalMatch = lastPart.match(/^(\d{5})\s+(.+)$/);
const postalCode = postalMatch?.[1];
const locality = postalMatch?.[2] ?? lastPart;
const streetAddress = addressParts.slice(0, -1).join(', ') || lastPart;

const organizationSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: settings.nom_asso,
  url: settings.url,
  logo: new URL('/brand/logo.svg', settings.url).toString(),
  email: settings.email_contact,
  telephone: settings.telephone,
  description: settings.mission,
  address: {
    '@type': 'PostalAddress',
    streetAddress,
    ...(postalCode ? { postalCode } : {}),
    addressLocality: locality,
    addressCountry: 'FR',
  },
  sameAs: [
    settings.reseaux.facebook,
    settings.reseaux.instagram,
    settings.reseaux.linkedin,
  ].filter((u): u is string => Boolean(u)),
};

const extraSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [organizationSchema, ...extraSchemas];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImagePath, settings.url).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImagePath, settings.url).toString()} />
    <meta property="og:locale" content="fr_FR" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {
      !noindex &&
        schemas.map((schema) => (
          <script
            type="application/ld+json"
            is:inline
            set:html={JSON.stringify(schema)}
          />
        ))
    }

    <!-- Preload fonts -->
    <link
      rel="preload"
      href="/fonts/nunito-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/nunito-bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#contenu" class="skip-link">Aller au contenu principal</a>
    {showBandero && <Banderole message={bandero!.message!} couleur={bandero!.couleur} />}
    <Header settings={settings} />
    <Breadcrumbs />
    <main id="contenu" class="flex-1">
      <slot />
    </main>
    {
      !noindex && (
        <section class="border-t border-beige bg-paper">
          <div class="mx-auto flex max-w-6xl items-center justify-center gap-3 px-4 py-6 md:justify-end">
            <p class="text-sm opacity-70">Cette page vous inspire ?</p>
            <ShareButton title={fullTitle} />
          </div>
        </section>
      )
    }
    <Footer settings={settings} />
  </body>
</html>
