---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';

const page = await getEntry('pages', 'mentions-legales');
if (!page) throw new Error("content/pages/mentions-legales.md introuvable");
---

<Layout title={page.data.title} description={page.data.description} noindex={page.data.noindex}>
  <PageRenderer page={page} />
</Layout>
