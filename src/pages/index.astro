---
import { getEntry, getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';
import Section from '../components/Section.astro';
import BlocCitation from '../components/BlocCitation.astro';
import Draft from '../components/Draft.astro';
import DraftBadge from '../components/DraftBadge.astro';
import { getSiteSettings } from '../lib/site';
import { filterPublished } from '../lib/drafts';

const page = await getEntry('pages', 'accueil');
if (!page) throw new Error('content/pages/accueil.md introuvable');

const settings = await getSiteSettings();

// Témoignage à la une : premier témoignage avec a_la_une = true,
// sinon premier de la liste, sinon rien.
const allTemoignages = filterPublished(await getCollection('temoignages')).sort(
  (a, b) => a.data.ordre - b.data.ordre,
);
const featured = allTemoignages.find((t) => t.data.a_la_une) ?? allTemoignages[0];
const FeaturedContent = featured ? (await render(featured)).Content : null;

// Prochains événements (3 max, à venir).
const now = new Date();
const aVenir = filterPublished(await getCollection('evenements'))
  .filter((e) => e.data.date_debut.valueOf() >= now.valueOf())
  .sort((a, b) => a.data.date_debut.valueOf() - b.data.date_debut.valueOf())
  .slice(0, 3);

function formatDate(d: Date): string {
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}

const hasFictiveEvents = aVenir.some((e) => e.data.fictif);
---

<Layout ogSlug="accueil">
  <PageRenderer page={page} />

  {
    featured && FeaturedContent && (
      <Section fond="beige">
        <DraftBadge draft={featured.data.draft} />
        {featured.data.fictif ? (
          <Draft reason={`Citation fictive — ${featured.data.auteur}`}>
            <BlocCitation
              variant="paper"
              auteur={featured.data.auteur}
              role={featured.data.role}
            >
              <FeaturedContent />
            </BlocCitation>
          </Draft>
        ) : (
          <BlocCitation
            variant="paper"
            auteur={featured.data.auteur}
            role={featured.data.role}
          >
            <FeaturedContent />
          </BlocCitation>
        )}
      </Section>
    )
  }

  <Section titre="Soutenir l'association" fond="violet">
    <div class="grid gap-8 md:grid-cols-2">
      <div>
        <p class="mb-4 text-lg leading-relaxed">
          75 adhérent·es et une centaine de soutiens individuels nous permettent déjà
          d'exister. Un don, une adhésion, du temps bénévole, un partenariat : chaque
          engagement compte.
        </p>
        <p class="mb-6 text-sm opacity-90">
          Montant libre, paiement 100 % sécurisé via HelloAsso. Reçu fiscal envoyé
          automatiquement (déduction à 66 %).
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={settings.helloasso_don}
            target="_blank"
            rel="noopener"
            class="rounded-full bg-orange px-6 py-3 font-bold text-paper hover:bg-magenta"
          >
            Faire un don
          </a>
          <a
            href="/agir/benevolat"
            class="rounded-full border-2 border-paper px-6 py-3 font-bold hover:bg-paper/10"
          >
            Devenir bénévole
          </a>
        </div>
      </div>
      {
        aVenir.length > 0 && (
          <div>
            {hasFictiveEvents ? (
              <Draft reason="Événements fictifs — à remplacer via le CMS">
                <div class="rounded-2xl bg-paper p-6 text-ink md:p-8">
                  <h2 class="mb-3 text-xl font-bold">Prochains rendez-vous</h2>
                  <ul class="space-y-3 text-sm">
                    {aVenir.map((e) => (
                      <li>
                        <DraftBadge draft={e.data.draft} />
                        <p class="font-semibold">{e.data.title}</p>
                        <p class="opacity-70">
                          {formatDate(e.data.date_debut)} · {e.data.lieu}
                        </p>
                      </li>
                    ))}
                  </ul>
                  <p class="mt-4">
                    <a
                      href="/agenda"
                      class="text-sm font-semibold text-orange hover:underline"
                    >
                      Voir l'agenda →
                    </a>
                  </p>
                </div>
              </Draft>
            ) : (
              <div class="rounded-2xl bg-paper p-6 text-ink md:p-8">
                <h2 class="mb-3 text-xl font-bold">Prochains rendez-vous</h2>
                <ul class="space-y-3 text-sm">
                  {aVenir.map((e) => (
                    <li>
                      <DraftBadge draft={e.data.draft} />
                      <p class="font-semibold">{e.data.title}</p>
                      <p class="opacity-70">
                        {formatDate(e.data.date_debut)} · {e.data.lieu}
                      </p>
                    </li>
                  ))}
                </ul>
                <p class="mt-4">
                  <a
                    href="/agenda"
                    class="text-sm font-semibold text-orange hover:underline"
                  >
                    Voir l'agenda →
                  </a>
                </p>
              </div>
            )}
          </div>
        )
      }
    </div>
  </Section>
</Layout>
