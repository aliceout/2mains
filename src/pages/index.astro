---
import { getEntry, getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';
import Section from '../components/Section.astro';
import BlocCitation from '../components/BlocCitation.astro';
import Draft from '../components/Draft.astro';
import DraftBadge from '../components/DraftBadge.astro';
import Btn from '../components/atoms/Btn.astro';
import Eyebrow from '../components/atoms/Eyebrow.astro';
import LinkArrow from '../components/atoms/LinkArrow.astro';
import { getSiteSettings } from '../lib/site';
import { filterPublished } from '../lib/drafts';

const page = await getEntry('pages', 'accueil');
if (!page) throw new Error('content/pages/accueil.md introuvable');

const settings = await getSiteSettings();

// Témoignage à la une : premier témoignage avec a_la_une = true,
// sinon premier de la liste, sinon rien.
const allTemoignages = filterPublished(await getCollection('temoignages')).sort(
  (a, b) => a.data.ordre - b.data.ordre,
);
const featured = allTemoignages.find((t) => t.data.a_la_une) ?? allTemoignages[0];
const FeaturedContent = featured ? (await render(featured)).Content : null;

// Prochains événements (3 max, à venir).
const now = new Date();
const aVenir = filterPublished(await getCollection('evenements'))
  .filter((e) => e.data.date_debut.valueOf() >= now.valueOf())
  .sort((a, b) => a.data.date_debut.valueOf() - b.data.date_debut.valueOf())
  .slice(0, 3);

function formatDate(d: Date): string {
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}

const hasFictiveEvents = aVenir.some((e) => e.data.fictif);
---

<Layout ogSlug="accueil">
  <PageRenderer page={page} />

  {
    featured && FeaturedContent && (
      <Section fond="beige">
        <DraftBadge draft={featured.data.draft} />
        {featured.data.fictif ? (
          <Draft reason={`Citation fictive — ${featured.data.auteur}`}>
            <BlocCitation
              variant="paper"
              auteur={featured.data.auteur}
              role={featured.data.role}
            >
              <FeaturedContent />
            </BlocCitation>
          </Draft>
        ) : (
          <BlocCitation
            variant="paper"
            auteur={featured.data.auteur}
            role={featured.data.role}
          >
            <FeaturedContent />
          </BlocCitation>
        )}
      </Section>
    )
  }

  <section class="border-t border-line">
    <div class="grid md:grid-cols-2">
      <div class="relative flex flex-col justify-between gap-8 bg-peach px-6 py-20 md:min-h-120 md:px-15 md:py-25">
        <div>
          <Eyebrow>— Soutenir</Eyebrow>
          <h2 class="font-serif text-4xl font-normal leading-tight tracking-tight text-ink md:text-5xl mt-4 mb-5 max-w-[14ch]">
            L'association tient debout grâce à <em class="font-medium not-italic text-orange">vous</em>.
          </h2>
          <p class="font-sans text-base leading-relaxed text-ink-2 max-w-[40ch] mb-8">
            Adhérer, donner ou devenir bénévole — chaque engagement compte. Un don de
            50 € permet à une femme de bénéficier d'une séance.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <Btn href={settings.helloasso_don} external arrow>Faire un don</Btn>
          <Btn variant="ghost" href="/agir/benevolat">Devenir bénévole</Btn>
        </div>
      </div>
      <div class="relative flex flex-col justify-between gap-8 bg-lav px-6 py-20 md:min-h-120 md:px-15 md:py-25">
        {aVenir.length > 0 ? (
          <>
            <div>
              <Eyebrow color="violet">— Prochain rendez-vous</Eyebrow>
              {hasFictiveEvents ? (
                <Draft reason="Événements fictifs — à remplacer via le CMS">
                  <ul class="mt-4 grid gap-5">
                    {aVenir.slice(0, 2).map((e) => (
                      <li>
                        <DraftBadge draft={e.data.draft} />
                        <div class="font-mono text-xs uppercase tracking-wider text-violet mt-1 mb-2">
                          {formatDate(e.data.date_debut).toUpperCase()} · {e.data.lieu.toUpperCase()}
                        </div>
                        <h3 class="font-serif text-2xl font-medium leading-tight tracking-tight text-ink max-w-[20ch]">
                          {e.data.title}
                        </h3>
                      </li>
                    ))}
                  </ul>
                </Draft>
              ) : (
                <ul class="mt-4 grid gap-5">
                  {aVenir.slice(0, 2).map((e) => (
                    <li>
                      <div class="font-mono text-xs uppercase tracking-wider text-violet mt-1 mb-2">
                        {formatDate(e.data.date_debut).toUpperCase()} · {e.data.lieu.toUpperCase()}
                      </div>
                      <h3 class="font-serif text-2xl font-medium leading-tight tracking-tight text-ink max-w-[20ch]">
                        {e.data.title}
                      </h3>
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <LinkArrow href="/agenda" color="violet">Voir l'agenda</LinkArrow>
          </>
        ) : (
          <>
            <div>
              <Eyebrow color="violet">— Newsletter saisonnière</Eyebrow>
              <h2 class="font-serif text-3xl font-normal leading-tight tracking-tight text-ink mt-4 mb-4 max-w-[16ch] md:text-4xl">
                Une <em class="font-medium not-italic text-violet">lettre</em> par saison.
              </h2>
              <p class="font-sans text-base leading-relaxed text-ink-2 max-w-[40ch]">
                Une lettre par saison — actualités, ateliers à venir, lectures et ressources.
              </p>
            </div>
            <LinkArrow href="/contact" color="violet">Nous écrire</LinkArrow>
          </>
        )}
      </div>
    </div>
  </section>
</Layout>
