---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import BlocCitation from '../../components/BlocCitation.astro';
import { site } from '../../config/site';
---

<Layout
  title="Pour les structures d'accueil"
  description="Enrichissez vos accompagnements en intégrant le toucher relationnel : parcours, ateliers collectifs et formations pour vos équipes."
>
  <Hero
    titre="Vous êtes une structure d'accueil"
    sousTitre="Nos activités"
    accroche="Foyer, CHRS, maison des femmes, EHPAD, centre social, maison relais… Nous intervenons là où les femmes sont déjà accueillies, en coopération étroite avec vos équipes."
    variant="bleu"
    ctaPrimaire={{ label: "Organiser une rencontre", href: '/contact' }}
    ctaSecondaire={{ label: `Nous écrire`, href: `mailto:${site.contact.email}`, externe: true }}
  />

  <Section titre="Notre promesse">
    <Prose>
      <p>
        Nous <strong>ne nous substituons pas</strong> aux accompagnements existants. Nous
        venons <strong>compléter</strong> votre offre en apportant une dimension absente des
        pratiques classiques : la <strong>reconnexion au corps et aux autres par le toucher
        relationnel</strong>.
      </p>
      <p>
        Concrètement, nous proposons des parcours progressifs et personnalisés auprès des
        femmes que vous accompagnez, dans vos locaux (ou à proximité si besoin), à un rythme
        hebdomadaire, avec une évaluation partagée.
      </p>
    </Prose>
  </Section>

  <Section titre="Nos formats" fond="beige">
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: 'Parcours individuels',
          description:
            "4 à 24 séances hebdomadaires selon les besoins. Chaque séance est construite avec la femme : respiration, automassage, éveil corporel, massage, écoute active.",
          couleur: 'orange',
        },
        {
          titre: 'Ateliers collectifs',
          description:
            "Auto-massages, jeux tactiles, consentement, respiration : des temps sécurisés pour créer du lien entre femmes et réinvestir son corps.",
          couleur: 'violet',
        },
        {
          titre: "Ateliers découverte",
          description:
            "Format court (1h30–2h), porte d'entrée aux activités. Animés par un·e bénévole intervenant·e, idéal pour un premier contact avec les femmes accueillies.",
          couleur: 'magenta',
        },
        {
          titre: 'Formations équipes',
          description:
            "Pour vos professionnel·les : la place des corps et du toucher dans l'accompagnement. Formats de 2h à 1 journée.",
          couleur: 'bleu',
        },
        {
          titre: 'Groupes de parole pros',
          description:
            "Échanges de pratiques sur le toucher, la bonne distance, la sécurité corporelle — pour des équipes qui accompagnent des publics vulnérables.",
          couleur: 'vert',
        },
        {
          titre: 'Conférences & tables rondes',
          description:
            "Sur demande : intervention publique ou interne pour donner de la visibilité au sujet de l'isolement corporel.",
          couleur: 'magenta',
        },
      ]}
    />
  </Section>

  <Section titre="Comment on travaille ensemble">
    <Prose>
      <ol>
        <li>
          <strong>Temps de rencontre</strong> — nous venons sur place, nous écoutons vos
          besoins et ceux des femmes que vous accompagnez.
        </li>
        <li>
          <strong>Coconstruction du cadre</strong> — choix des formats, fréquence, lieu,
          modalités d'orientation, référent·e dans votre équipe.
        </li>
        <li>
          <strong>Convention de partenariat</strong> — mise à disposition de locaux et
          engagement d'au moins 2 professionnel·les de votre équipe à titre de relais.
        </li>
        <li>
          <strong>Déploiement des parcours</strong> — avec des points réguliers équipe /
          intervenant·es / femmes.
        </li>
        <li>
          <strong>Évaluation partagée</strong> — 3 temps minimum (avant, pendant, après),
          avec des outils coconstruits pour mesurer effets et satisfaction.
        </li>
      </ol>
    </Prose>
  </Section>

  <Section fond="beige">
    <BlocCitation
      variant="paper"
      citation="Nous cherchions depuis longtemps à intégrer la dimension corporelle dans nos accompagnements, sans savoir par où commencer. 2mains de femmes nous a apporté un cadre, une méthode, et surtout des intervenantes formées qui respectent nos bénéficiaires."
      auteur="Témoignage partenaire"
      role="Association d'hébergement, Lyon — témoignage à compléter"
    />
  </Section>

  <Section fond="bleu">
    <Prose>
      <h2 class="!text-paper">Envie d'en parler ?</h2>
      <p class="!text-paper">
        Nous accueillons toute demande — même exploratoire. Un café, un appel, une visite de
        votre structure, et on voit ce qu'on peut construire ensemble.
      </p>
      <p class="!text-paper">
        <a href="/contact" class="!text-paper !underline">Prendre contact →</a>
      </p>
    </Prose>
  </Section>
</Layout>
