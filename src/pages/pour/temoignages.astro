---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocCitation from '../../components/BlocCitation.astro';
---

<Layout
  title="Ils nous ont fait confiance"
  description="Paroles de participantes, de partenaires et de professionnel·les autour des parcours d'accompagnement corporel."
>
  <Hero
    titre="Ils nous ont fait confiance"
    sousTitre="Nos activités"
    accroche="Des voix qui racontent — à leur manière — ce que le toucher relationnel a changé dans leur parcours ou dans leur pratique."
    variant="beige"
  />

  <Section titre="Paroles de participantes">
    <div class="grid gap-6 md:grid-cols-2">
      <BlocCitation
        variant="paper"
        citation="Pendant longtemps, je pensais que mon corps était juste un problème. Là, c'est la première fois depuis des années que quelqu'un me touche sans rien me demander en retour. Ça change tout."
        auteur="Leïla"
        role="Participante, 42 ans"
      />
      <BlocCitation
        variant="paper"
        citation="Je suis arrivée méfiante. On m'avait dit que je pouvais dire non, et je l'ai dit, souvent. Et puis un jour j'ai dit oui, et j'ai pleuré, et ça m'a fait du bien de pleurer dans un endroit où j'étais en sécurité."
        auteur="Marion"
        role="Participante, 56 ans"
      />
      <BlocCitation
        variant="paper"
        citation="Après les ateliers collectifs, on reste entre nous. On parle. Ça me manquait, ce genre de moments avec d'autres femmes. Je me sens moins seule."
        auteur="Fatoumata"
        role="Participante, 34 ans"
      />
      <BlocCitation
        variant="paper"
        citation="J'ai appris à m'auto-masser les mains. Ça a l'air bête, mais le soir, quand je n'arrive pas à dormir, je le fais et ça m'apaise."
        auteur="Claire"
        role="Participante, 68 ans"
      />
    </div>
  </Section>

  <Section titre="Paroles de partenaires" fond="beige">
    <div class="grid gap-6 md:grid-cols-2">
      <BlocCitation
        variant="paper"
        citation="Nous cherchions depuis longtemps à intégrer une dimension corporelle dans nos accompagnements, sans savoir comment. 2mains de femmes a apporté une méthode, un cadre, et surtout une écoute réelle de ce que nos bénéficiaires vivent."
        auteur="Équipe associative"
        role="CHRS lyonnais — structure partenaire"
      />
      <BlocCitation
        variant="paper"
        citation="L'approche complète vraiment nos actions. Les femmes que nous orientons reviennent nous voir avec un rapport à elles-mêmes différent. C'est un apport qualitatif qu'on ne soupçonnait pas."
        auteur="Coordinatrice sociale"
        role="Accueil de jour, Lyon"
      />
    </div>
  </Section>

  <Section titre="Paroles de professionnel·les">
    <div class="grid gap-6 md:grid-cols-2">
      <BlocCitation
        variant="paper"
        citation="Intervenir auprès de femmes en grande fragilité demande un cadre exigeant. Chez 2mains de femmes, on pense le toucher comme une éthique, pas comme une technique. Ça change ma pratique de masseuse."
        auteur="Praticienne solidaire"
        role="Réseau des Mains de 2mains"
      />
      <BlocCitation
        variant="paper"
        citation="La formation sur le toucher relationnel m'a fait repenser ma posture, y compris dans des gestes très simples comme poser une main sur une épaule lors d'un entretien."
        auteur="Travailleuse sociale"
        role="Lyon"
      />
    </div>
  </Section>

  <Section fond="violet">
    <Prose>
      <p class="!text-paper text-sm opacity-90">
        <em>
          Les prénoms des participantes sont des pseudonymes. Les témoignages, recueillis
          avec consentement, sont illustratifs des paroles entendues lors de nos actions —
          et appelés à être complétés au fil des parcours.
        </em>
      </p>
    </Prose>
  </Section>
</Layout>
