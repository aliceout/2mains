---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import BlocCitation from '../../components/BlocCitation.astro';
import Draft from '../../components/Draft.astro';
import DraftBadge from '../../components/DraftBadge.astro';
import { filterPublished } from '../../lib/drafts';

const page = await getEntry('pages', 'temoignages');
if (!page) throw new Error('content/pages/temoignages.md introuvable');

const all = filterPublished(await getCollection('temoignages')).sort(
  (a, b) => a.data.ordre - b.data.ordre,
);

type Item = CollectionEntry<'temoignages'>;

async function renderGroup(items: Item[]) {
  return Promise.all(
    items.map(async (t) => {
      const { Content } = await render(t);
      return { ...t, Content };
    }),
  );
}

const groups = [
  {
    titre: 'Paroles de participantes',
    fond: undefined as 'beige' | undefined,
    items: await renderGroup(all.filter((t) => t.data.contexte === 'participante')),
    draftReason: 'Témoignages fictifs — à remplacer par de vraies paroles',
  },
  {
    titre: 'Paroles de partenaires',
    fond: 'beige' as const,
    items: await renderGroup(all.filter((t) => t.data.contexte === 'partenaire')),
    draftReason: 'Témoignages partenaires fictifs — à solliciter auprès des structures',
  },
  {
    titre: 'Paroles de professionnel·les',
    fond: undefined,
    items: await renderGroup(all.filter((t) => t.data.contexte === 'professionnelle')),
    draftReason: 'Témoignages pros fictifs — à solliciter auprès du réseau',
  },
];
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.id}>
  {page.data.hero && <Hero {...page.data.hero} />}

  {
    groups.map((g) =>
      g.items.length === 0 ? null : (
        <Section titre={g.titre} fond={g.fond}>
          {g.items.some((t) => t.data.fictif) ? (
            <Draft reason={g.draftReason}>
              <div class="grid gap-6 md:grid-cols-2">
                {g.items.map(({ data, Content }) => (
                  <div>
                    <DraftBadge draft={data.draft} />
                    <BlocCitation variant="paper" auteur={data.auteur} role={data.role}>
                      <Content />
                    </BlocCitation>
                  </div>
                ))}
              </div>
            </Draft>
          ) : (
            <div class="grid gap-6 md:grid-cols-2">
              {g.items.map(({ data, Content }) => (
                <div>
                  <DraftBadge draft={data.draft} />
                  <BlocCitation variant="paper" auteur={data.auteur} role={data.role}>
                    <Content />
                  </BlocCitation>
                </div>
              ))}
            </div>
          )}
        </Section>
      ),
    )
  }

  {
    all.length === 0 && (
      <Section>
        <p class="text-sm opacity-70">Aucun témoignage publié pour l'instant.</p>
      </Section>
    )
  }
</Layout>
