---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocCartes from '../../components/BlocCartes.astro';
---

<Layout
  title="Pour les entreprises"
  description="Mécénat, ateliers de sensibilisation, engagements solidaires : plusieurs manières pour votre entreprise de soutenir 2mains de femmes."
>
  <Hero
    titre="Vous êtes une entreprise"
    sousTitre="Nos activités"
    accroche="Soutenir un projet d'innovation sociale qui touche à la santé mentale, au lien social et à l'égalité de genre — c'est affirmer des engagements concrets, bien au-delà de la RSE de surface."
    variant="vert"
    ctaPrimaire={{ label: "Devenir mécène", href: '/soutenir/mecenat' }}
    ctaSecondaire={{ label: 'Nous contacter', href: '/contact' }}
  />

  <Section titre="Pourquoi nous soutenir ?">
    <Prose>
      <p>
        2mains de femmes répond à un <strong>impensé social</strong> : l'absence de toucher
        relationnel comme facteur d'isolement, de mal-être et d'inégalité. En nous soutenant,
        votre entreprise contribue à :
      </p>
      <ul>
        <li>
          Rendre accessibles des accompagnements <strong>gratuits</strong> pour des femmes qui
          cumulent précarité, isolement et parfois violences.
        </li>
        <li>
          Documenter et diffuser une approche innovante, susceptible d'essaimer dans d'autres
          métropoles.
        </li>
        <li>
          Former des professionnel·les du social, du médico-social et de la santé à une
          dimension absente de leurs pratiques.
        </li>
        <li>
          Soutenir une association lyonnaise ancrée, participative, et dont les décisions
          sont prises par les personnes concernées.
        </li>
      </ul>
    </Prose>
  </Section>

  <Section titre="Comment vous engager" fond="beige">
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: 'Mécénat financier',
          description:
            "Un don ponctuel ou récurrent, défiscalisable à 60 % dans la limite de 0,5 % du CA. Les fonds soutiennent directement les parcours d'accompagnement des femmes.",
          href: '/soutenir/mecenat',
          cta: 'Mécénat',
          couleur: 'orange',
        },
        {
          titre: 'Mécénat en nature',
          description:
            "Mise à disposition de locaux, de matériel, de compétences (communication, compta, juridique, tech), de temps salarié. Également défiscalisable.",
          href: '/contact',
          cta: 'En parler',
          couleur: 'violet',
        },
        {
          titre: 'Ateliers sur mesure',
          description:
            "Ateliers de sensibilisation pour vos équipes : toucher au travail, consentement, inclusion, santé mentale. Formats de 1h à une journée.",
          href: '/contact',
          cta: 'Demander un devis',
          couleur: 'magenta',
        },
      ]}
    />
  </Section>

  <Section titre="Nos engagements envers nos mécènes">
    <Prose>
      <ul>
        <li>
          <strong>Transparence</strong> : rapport d'utilisation des fonds, bilan annuel,
          indicateurs d'impact.
        </li>
        <li>
          <strong>Visibilité</strong> (selon souhait) : logo, témoignage, événements communs.
        </li>
        <li>
          <strong>Lien direct</strong> avec les équipes et les actions : visites de terrain,
          rencontres avec des participantes volontaires.
        </li>
        <li>
          <strong>Reçu fiscal</strong> transmis automatiquement.
        </li>
      </ul>
    </Prose>
  </Section>

  <Section fond="vert">
    <Prose>
      <h2>Envie d'un premier échange ?</h2>
      <p>
        Nous adaptons nos propositions à la taille, au secteur et à la sensibilité de votre
        entreprise. Un appel de 20 minutes suffit souvent à savoir ce qui peut se construire.
      </p>
      <p>
        <a href="/contact">Prendre rendez-vous →</a>
      </p>
    </Prose>
  </Section>
</Layout>
