---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import Prose from '../../components/Prose.astro';
---

<Layout
  title="Nos activités"
  description="Selon que vous êtes une structure d'accueil, une entreprise ou une femme concernée, nos formats et modalités d'intervention."
>
  <Hero
    titre="Nos activités"
    accroche="Nos interventions s'adaptent à chaque public. Que vous soyez une structure qui accueille des femmes, une entreprise qui souhaite s'engager, ou une femme cherchant un espace pour retrouver un rapport apaisé à son corps — voici ce que nous proposons."
    variant="orange"
  />

  <Section>
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: "Vous êtes une structure d'accueil",
          description:
            "Enrichissez vos accompagnements en intégrant le toucher relationnel. Parcours sur site, ateliers collectifs, formations des équipes.",
          href: '/pour/structures',
          cta: 'Nos formats',
          couleur: 'bleu',
        },
        {
          titre: 'Vous êtes une entreprise',
          description:
            "Mécénat, ateliers de sensibilisation, engagements solidaires : soutenez un projet d'innovation sociale qui touche à la santé mentale et à l'égalité.",
          href: '/pour/entreprises',
          cta: "S'engager",
          couleur: 'vert',
        },
        {
          titre: 'Vous êtes une femme concernée',
          description:
            "Nos parcours sont gratuits, respectueux de votre rythme et de votre consentement. Nous vous rencontrons là où vous êtes, en lien avec les structures qui vous accompagnent.",
          href: '/pour/femmes',
          cta: 'Nous rencontrer',
          couleur: 'magenta',
        },
      ]}
    />
  </Section>

  <Section titre="Et celles et ceux qui nous font confiance" fond="beige">
    <Prose>
      <p>
        Des partenaires associatifs, des financeurs publics, des praticien·nes solidaires :
        nous construisons avec une communauté grandissante.
      </p>
      <p>
        <a href="/pour/temoignages">Voir les témoignages →</a>
      </p>
    </Prose>
  </Section>
</Layout>
