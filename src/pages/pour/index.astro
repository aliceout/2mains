---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageRenderer from '../../components/PageRenderer.astro';

const page = await getEntry('pages', 'pour');
if (!page) throw new Error("content/pages/pour.md introuvable");
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.id} noindex={page.data.noindex}>
  <PageRenderer page={page} />
</Layout>
