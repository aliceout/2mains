---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import { site } from '../../config/site';
---

<Layout
  title="Devenir bénévole"
  description="Trois profils de bénévolat à 2mains de femmes : intervenant·e, appui développement, ponctuel·le. Rejoignez les Mains de 2mains."
>
  <Hero
    titre="Devenir bénévole"
    sousTitre="Agir avec nous"
    accroche="Les bénévoles — les Mains de 2mains — sont l'ossature de l'association. Trois profils cohabitent, cumulables, à adapter à vos envies, vos compétences et vos disponibilités."
    variant="violet"
    ctaPrimaire={{
      label: 'Répondre au questionnaire bénévoles',
      href: 'https://forms.office.com/r/32MgiHRm86',
      externe: true,
    }}
    ctaSecondaire={{ label: 'Nous écrire', href: '/contact' }}
  />

  <Section titre="Les trois profils">
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: '1. Intervenant·e',
          description:
            "Vous animez directement — seul·e ou en binôme — des parcours individuels ou des ateliers collectifs auprès des femmes accompagnées. Engagement régulier, formation offerte par l'association.",
          couleur: 'orange',
        },
        {
          titre: '2. Appui développement',
          description:
            "Vous participez à une commission technique (projet associatif, recherche de fonds, réseau pro, communication). Une réunion tous les 4 mois minimum, plus du travail entre les sessions selon envie.",
          couleur: 'violet',
        },
        {
          titre: '3. Ponctuel·le',
          description:
            "Vous êtes mobilisable sur des chantiers courts : logistique d'un événement, création d'un outil, campagne de com, graphisme, relecture, traduction…",
          couleur: 'magenta',
        },
      ]}
    />
    <p class="mt-6 text-sm opacity-80">
      Les profils sont <strong>cumulables</strong> : on peut parfaitement être intervenante le
      mardi et membre d'une commission en parallèle.
    </p>
  </Section>

  <Section titre="Ce qu'on propose en retour" fond="beige">
    <Prose>
      <ul>
        <li>
          <strong>Des formations gratuites</strong> — au moins une journée par an sur le
          toucher relationnel, animée par un·e professionnel·le extérieur·e.
        </li>
        <li>
          <strong>Un apéro des bénévoles régulier</strong> — un jeudi soir par mois au tiers
          lieu Pôle Bert à Lyon. Pour se connaître, se raconter, s'entraider.
        </li>
        <li>
          <strong>Un cadre de supervision</strong> pour les bénévoles intervenant·es.
        </li>
        <li>
          <strong>Une vraie participation aux décisions</strong> — l'association est
          gouvernée de manière participative, pas hiérarchique.
        </li>
        <li>
          <strong>Une communauté</strong> de femmes et d'allié·es engagé·es sur un sujet
          politique, intime et puissant.
        </li>
      </ul>
    </Prose>
  </Section>

  <Section titre="Comment commencer ?">
    <Prose>
      <ol>
        <li>
          <strong>Remplir le questionnaire bénévoles</strong> (10 min) pour nous présenter
          vos disponibilités et envies :{' '}
          <a
            href="https://forms.office.com/r/32MgiHRm86"
            target="_blank"
            rel="noopener"
          >
            formulaire en ligne
          </a>
          .
        </li>
        <li>
          <strong>Venir à un apéro bénévoles</strong> — on se rencontre, on discute, aucun
          engagement à ce stade.
        </li>
        <li>
          <strong>On construit ensemble</strong> votre implication.
        </li>
      </ol>
      <p>
        Des questions ? Écrivez à
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>.
      </p>
    </Prose>
  </Section>
</Layout>
