---
// Page /demo — catalogue visuel de tous les blocs CMS. Non indexée,
// exclue du sitemap et de robots.txt. Sert de référence à Audrey et
// d'aide-mémoire visuel pour vérifier le rendu des blocs.
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';
import MissingPageFallback from '../components/MissingPageFallback.astro';
import { fetchPageLegacy } from '../lib/payload';

const page = await fetchPageLegacy('demo');
const hasContent =
  Boolean(page?.data.hero?.titre) || Boolean(page?.data.sections?.length);
const fallbackTitle = 'Catalogue des blocs (demo)';
---

<Layout
  title={hasContent && page ? page.data.title : fallbackTitle}
  description={hasContent && page ? page.data.description : undefined}
  ogSlug={page?.slug ?? 'demo'}
  noindex={hasContent && page ? page.data.noindex : true}
>
  {hasContent && page ? <PageRenderer page={page} /> : <MissingPageFallback title={fallbackTitle} />}
</Layout>
