---
// SSR : opt-in explicite (sinon Astro 6 demande un getStaticPaths,
// or les slugs viennent de Payload à l'exécution).
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import { getSiteSettings } from '../../lib/site';
import { fetchBySlug, mediaUrl } from '../../lib/payload';
import { lexicalToHtml, lexicalToPlainText } from '../../lib/lexical';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/actualites', 302);

type PostDoc = {
  slug: string;
  title: string;
  /** Chapô Lexical (richText). */
  description_rich?: unknown;
  date: string;
  auteur?: string;
  cover?: { filename?: string };
  cover_alt?: string;
  tags?: Array<{ tag: string }>;
  /** Corps Lexical (richText). */
  body_rich?: unknown;
  draft?: boolean;
};

const post = await fetchBySlug<PostDoc>('actualites', slug);
if (!post) return new Response('Article introuvable', { status: 404 });

const settings = await getSiteSettings();

const coverUrl = mediaUrl(post.cover?.filename) ?? undefined;

const tags = (post.tags ?? []).map((t) => t.tag);
const bodyHtml = lexicalToHtml(post.body_rich);
// Description plain-text pour le SEO/<meta>/JSON-LD.
const descriptionPlain = post.description_rich
  ? lexicalToPlainText(post.description_rich)
  : undefined;

function formatDate(s: string): string {
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(s));
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.title,
  datePublished: post.date,
  ...(descriptionPlain ? { description: descriptionPlain } : {}),
  ...(coverUrl ? { image: coverUrl } : {}),
  ...(post.auteur ? { author: { '@type': 'Person', name: post.auteur } } : {}),
  publisher: {
    '@type': 'NGO',
    name: settings.nom_asso,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/brand/logo.svg', settings.url ?? process.env.ADDRESS!).toString(),
    },
  },
  mainEntityOfPage: new URL(
    `/actualites/${post.slug}`,
    settings.url ?? process.env.ADDRESS!,
  ).toString(),
};
---

<Layout
  title={post.title}
  description={descriptionPlain}
  image={`/og/actualites/${post.slug}.png`}
  jsonLd={articleSchema}
>
  <Hero
    titre={post.title}
    sousTitre={formatDate(post.date)}
    accroche={descriptionPlain}
    variant="beige"
  />

  {coverUrl && (
    <Section>
      <img
        src={coverUrl}
        alt={post.cover_alt ?? ''}
        class="mx-auto w-full max-w-4xl rounded-xl"
      />
    </Section>
  )}

  <Section>
    <Prose>
      <Fragment set:html={bodyHtml} />
    </Prose>

    {tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {tags.map((t) => (
          <span class="rounded-full bg-cream px-3 py-1 text-sm">#{t}</span>
        ))}
      </div>
    )}

    {post.auteur && (
      <p class="mt-6 text-sm opacity-70">Écrit par {post.auteur}</p>
    )}

    <p class="mt-10">
      <a href="/actualites" class="font-semibold text-orange hover:underline">
        ← Retour aux actualités
      </a>
    </p>
  </Section>
</Layout>
