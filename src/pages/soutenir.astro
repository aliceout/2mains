---
// Page d'aiguillage « Soutenir » — accessible via le bouton Soutenir du
// header. Liste les façons de soutenir financièrement l'asso.
//
// Pattern résilient : si Audrey crée la page « soutenir » dans Payload,
// son contenu prend le dessus. Sinon, on rend un fallback hard-codé avec
// hero + 2 cartes (don, mécénat).
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { fetchPageLegacy } from '../lib/payload';

const page = await fetchPageLegacy('soutenir');
const hasContent =
  Boolean(page?.data.hero?.titre) || Boolean(page?.data.sections?.length);

const cards = [
  {
    label: 'Faire un don',
    href: '/dons',
    desc: 'Don ponctuel ou régulier. Déductible des impôts à 66 %.',
  },
  {
    label: "Mécénat d'entreprise",
    href: '/mecenat',
    desc: "Mécénat financier, en nature ou de compétences. Avantage fiscal de 60 %.",
  },
];
---

{
  hasContent && page ? (
    <Layout title={page.data.title} description={page.data.description} ogSlug={page.slug} noindex={page.data.noindex}>
      <PageRenderer page={page} />
    </Layout>
  ) : (
    <Layout
      title="Soutenir"
      description="Soutenir financièrement 2mains de femmes : faire un don, mécénat d'entreprise."
    >
      <Hero
        titre="*Soutenir* l'association"
        sousTitre="Engagement financier"
        accroche="Chaque contribution permet d'élargir l'accès au toucher relationnel pour des femmes qui n'y auraient pas accès autrement."
        variant="orange"
      />

      <Section>
        <ul class="grid gap-6 md:grid-cols-2">
          {cards.map((card) => (
            <li>
              <a
                href={card.href}
                class="flex h-full flex-col rounded-2xl border border-line bg-paper p-6 transition-opacity hover:opacity-90"
              >
                <h2 class="font-serif text-xl font-bold leading-tight">{card.label}</h2>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-2">{card.desc}</p>
                <span class="mt-6 font-sans text-sm font-semibold text-orange">
                  En savoir plus →
                </span>
              </a>
            </li>
          ))}
        </ul>
      </Section>
    </Layout>
  )
}
