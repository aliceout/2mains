---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import DraftBadge from '../components/DraftBadge.astro';
import { filterPublished } from '../lib/drafts';
import { fetchPageLegacy, fetchCollectionLegacy } from '../lib/payload';

const page = await fetchPageLegacy('documents');
if (!page) throw new Error('Page documents introuvable dans Payload');

type Doc = {
  titre: string;
  categorie: string;
  fichier?: string;
  date?: string;
  description_courte?: string;
  a_paraitre?: boolean;
  draft?: boolean;
};
const docs = filterPublished(
  await fetchCollectionLegacy<Doc>('documents'),
).sort((a, b) => {
  if (a.data.a_paraitre !== b.data.a_paraitre) return a.data.a_paraitre ? 1 : -1;
  const da = a.data.date ? Date.parse(a.data.date) : 0;
  const db = b.data.date ? Date.parse(b.data.date) : 0;
  return db - da;
});

function formatDate(s: string | undefined): string {
  if (!s) return 'À paraître';
  return new Intl.DateTimeFormat('fr-FR', { month: 'long', year: 'numeric' }).format(new Date(s));
}
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.slug}>
  {page.data.hero && <Hero {...page.data.hero} />}

  <Section>
    <ul class="grid gap-4 md:grid-cols-2">
      {
        docs.map((d) => (
          <li class="flex flex-col rounded-xl border border-line bg-paper p-6">
            <DraftBadge draft={d.data.draft} />
            <p class="text-xs font-semibold tracking-wide uppercase text-violet">
              {d.data.categorie} · {formatDate(d.data.date)}
            </p>
            <h2 class="mt-2 mb-2 text-xl font-bold">{d.data.titre}</h2>
            {d.data.description_courte && (
              <p class="mb-4 flex-1 text-sm leading-relaxed">
                {d.data.description_courte}
              </p>
            )}
            {d.data.a_paraitre ? (
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-line px-4 py-2 text-sm font-semibold opacity-70">
                À paraître
              </span>
            ) : d.data.fichier ? (
              <a
                href={d.data.fichier}
                class="inline-flex w-fit items-center gap-2 rounded-full bg-orange px-4 py-2 text-sm font-bold text-paper hover:opacity-85"
              >
                Télécharger le PDF →
              </a>
            ) : (
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-line px-4 py-2 text-sm font-semibold opacity-70">
                Disponible sur demande
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </Section>
</Layout>
