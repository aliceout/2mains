---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageRenderer from '../components/PageRenderer.astro';

const page = await getEntry('pages', 'politique-confidentialite');
if (!page) throw new Error("content/pages/politique-confidentialite.md introuvable");
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.id} noindex={page.data.noindex}>
  <PageRenderer page={page} />
</Layout>
