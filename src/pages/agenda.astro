---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Prose from '../components/Prose.astro';
import Draft from '../components/Draft.astro';
import { getSiteSettings } from '../lib/site';

const page = await getEntry('pages', 'agenda');
if (!page) throw new Error('content/pages/agenda.md introuvable');

type Item = CollectionEntry<'evenements'>;

async function withContent(items: Item[]) {
  return Promise.all(
    items.map(async (e) => {
      const { Content } = await render(e);
      return { ...e, Content };
    }),
  );
}

const all = (await getCollection('evenements')).sort(
  (a, b) => a.data.date_debut.valueOf() - b.data.date_debut.valueOf(),
);

const now = new Date();
const aVenir = await withContent(
  all.filter((e) => e.data.date_debut.valueOf() >= now.valueOf()),
);
const passes = all
  .filter((e) => e.data.date_debut.valueOf() < now.valueOf())
  .reverse();

const hasFictive = aVenir.some((e) => e.data.fictif);

const settings = await getSiteSettings();
const feedHttps = new URL('/agenda.ics', settings.url).toString();
const feedWebcal = feedHttps.replace(/^https?:/, 'webcal:');

const eventSchemas = aVenir
  .filter((e) => !e.data.fictif)
  .map((e) => ({
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: e.data.title,
    startDate: e.data.date_debut.toISOString(),
    ...(e.data.date_fin ? { endDate: e.data.date_fin.toISOString() } : {}),
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: {
      '@type': 'Place',
      name: e.data.lieu,
      ...(e.data.adresse ? { address: e.data.adresse } : {}),
    },
    organizer: {
      '@type': 'NGO',
      name: settings.nom_asso,
      url: settings.url,
    },
    isAccessibleForFree: e.data.gratuit,
    ...(e.data.inscription_url ? { url: e.data.inscription_url } : {}),
  }));

function formatDateFull(debut: Date, fin?: Date): string {
  const dOpts: Intl.DateTimeFormatOptions = {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  };
  const tOpts: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };
  const d = new Intl.DateTimeFormat('fr-FR', dOpts).format(debut);
  const h1 = new Intl.DateTimeFormat('fr-FR', tOpts).format(debut);
  if (fin && fin.toDateString() === debut.toDateString()) {
    const h2 = new Intl.DateTimeFormat('fr-FR', tOpts).format(fin);
    return `${d}, ${h1}–${h2}`;
  }
  return `${d}, ${h1}`;
}
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.id} jsonLd={eventSchemas}>
  {page.data.hero && <Hero {...page.data.hero} />}

  <Section>
    <div
      class="flex flex-col gap-4 rounded-2xl border border-beige bg-paper p-6 md:flex-row md:items-center md:justify-between md:p-8"
    >
      <div class="max-w-2xl">
        <h2 class="text-xl font-bold md:text-2xl">S'abonner à l'agenda</h2>
        <p class="mt-2 text-sm leading-relaxed md:text-base">
          Ajoutez l'agenda complet à votre calendrier (Apple, Google, Outlook,
          Thunderbird). Les nouveaux événements apparaîtront automatiquement,
          sans revenir sur le site.
        </p>
      </div>
      <div class="flex flex-col items-start gap-2 md:items-end">
        <a
          href={feedWebcal}
          class="inline-flex items-center gap-2 rounded-full bg-orange px-5 py-2 text-sm font-bold text-paper hover:bg-magenta"
        >
          S'abonner
        </a>
        <a
          href={feedHttps}
          class="text-xs text-ink/60 underline-offset-2 hover:text-orange hover:underline"
        >
          ou copier le lien direct
        </a>
      </div>
    </div>
  </Section>

  <Section titre="À venir">
    {
      aVenir.length === 0 ? (
        <p class="text-sm opacity-70">
          Aucun événement programmé pour l'instant. Restez en lien par email.
        </p>
      ) : (
        <>
          {hasFictive ? (
            <Draft reason="Événements fictifs — à remplacer par les vrais via le CMS">
              <ul class="grid gap-4 md:grid-cols-2">
                {aVenir.map((e) => (
                  <li class="rounded-xl border border-beige bg-paper p-6">
                    <p class="text-xs font-semibold uppercase tracking-wide text-orange">
                      {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
                    </p>
                    <h2 class="mt-2 mb-1 text-xl font-bold">{e.data.title}</h2>
                    <div class="mb-3 flex flex-wrap gap-2 text-xs">
                      <span class="rounded-full bg-beige px-3 py-1">
                        {e.data.public}
                      </span>
                      {e.data.gratuit && (
                        <span class="rounded-full bg-vert px-3 py-1">Gratuit</span>
                      )}
                    </div>
                    <div class="text-sm leading-relaxed">
                      <e.Content />
                    </div>
                    <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
                      {e.data.inscription_url && (
                        <a
                          href={e.data.inscription_url}
                          class="font-semibold text-orange hover:underline"
                        >
                          S'inscrire / en savoir plus →
                        </a>
                      )}
                      <a
                        href={`/agenda/${e.id}.ics`}
                        download
                        class="text-sm text-ink/70 underline-offset-2 hover:text-orange hover:underline"
                      >
                        Ajouter à mon agenda
                      </a>
                    </div>
                  </li>
                ))}
              </ul>
            </Draft>
          ) : (
            <ul class="grid gap-4 md:grid-cols-2">
              {aVenir.map((e) => (
                <li class="rounded-xl border border-beige bg-paper p-6">
                  <p class="text-xs font-semibold uppercase tracking-wide text-orange">
                    {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
                  </p>
                  <h2 class="mt-2 mb-1 text-xl font-bold">{e.data.title}</h2>
                  <div class="mb-3 flex flex-wrap gap-2 text-xs">
                    <span class="rounded-full bg-beige px-3 py-1">{e.data.public}</span>
                    {e.data.gratuit && (
                      <span class="rounded-full bg-vert px-3 py-1">Gratuit</span>
                    )}
                  </div>
                  <div class="text-sm leading-relaxed">
                    <e.Content />
                  </div>
                  <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
                    {e.data.inscription_url && (
                      <a
                        href={e.data.inscription_url}
                        class="font-semibold text-orange hover:underline"
                      >
                        S'inscrire / en savoir plus →
                      </a>
                    )}
                    <a
                      href={`/agenda/${e.id}.ics`}
                      download
                      class="text-sm text-ink/70 underline-offset-2 hover:text-orange hover:underline"
                    >
                      Ajouter à mon agenda
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </>
      )
    }
  </Section>

  {
    passes.length > 0 && (
      <Section titre="Événements passés" fond="beige">
        <ul class="grid gap-3 md:grid-cols-2">
          {passes.map((e) => (
            <li class="rounded-lg bg-paper p-4 opacity-80">
              <p class="text-xs uppercase tracking-wide text-violet">
                {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
              </p>
              <p class="mt-1 font-semibold">{e.data.title}</p>
            </li>
          ))}
        </ul>
      </Section>
    )
  }

  <Section>
    <Prose>
      <p class="text-sm opacity-70">
        <em>
          Audrey peut ajouter, modifier et retirer les événements directement depuis
          l'admin du site — sans passer par le code.
        </em>
      </p>
    </Prose>
  </Section>
</Layout>
