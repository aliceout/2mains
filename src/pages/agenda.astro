---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Prose from '../components/Prose.astro';
import Draft from '../components/Draft.astro';
import DraftBadge from '../components/DraftBadge.astro';
import { getSiteSettings } from '../lib/site';
import { filterPublished } from '../lib/drafts';
import { fetchPageLegacy, fetchCollectionLegacy } from '../lib/payload';
import { lexicalToHtml } from '../lib/lexical';

const page = await fetchPageLegacy('agenda');
const hasContent = Boolean(page?.data.hero?.titre);
const fallbackTitle = 'Agenda';

type Evt = {
  title: string;
  date_debut: string;
  date_fin?: string;
  lieu: string;
  adresse?: string;
  public: string;
  gratuit: boolean;
  inscription_url?: string;
  /** Description Lexical (richText). */
  body_rich?: unknown;
  fictif?: boolean;
  draft?: boolean;
};

const all = filterPublished(
  await fetchCollectionLegacy<Evt>('evenements', { sort: 'date_debut' }),
);

const now = Date.now();
const aVenir = all
  .filter((e) => Date.parse(e.data.date_debut) >= now)
  .map((e) => ({
    ...e,
    bodyHtml: lexicalToHtml(e.data.body_rich),
  }));
const passes = all
  .filter((e) => Date.parse(e.data.date_debut) < now)
  .reverse();

const hasFictive = aVenir.some((e) => e.data.fictif);

const settings = await getSiteSettings();
const siteAddress = settings.url ?? process.env.ADDRESS;
if (!siteAddress) throw new Error('Site URL inconnue (settings.url + ADDRESS vides).');
const feedHttps = new URL('/agenda.ics', siteAddress).toString();
const feedWebcal = feedHttps.replace(/^https?:/, 'webcal:');

const eventSchemas = aVenir
  .filter((e) => !e.data.fictif)
  .map((e) => ({
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: e.data.title,
    startDate: e.data.date_debut,
    ...(e.data.date_fin ? { endDate: e.data.date_fin } : {}),
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: {
      '@type': 'Place',
      name: e.data.lieu,
      ...(e.data.adresse ? { address: e.data.adresse } : {}),
    },
    organizer: {
      '@type': 'NGO',
      name: settings.nom_asso,
      url: settings.url,
    },
    isAccessibleForFree: e.data.gratuit,
    ...(e.data.inscription_url ? { url: e.data.inscription_url } : {}),
  }));

function formatDateFull(debutStr: string, finStr?: string): string {
  const debut = new Date(debutStr);
  const fin = finStr ? new Date(finStr) : undefined;
  const dOpts: Intl.DateTimeFormatOptions = {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  };
  const tOpts: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };
  const d = new Intl.DateTimeFormat('fr-FR', dOpts).format(debut);
  const h1 = new Intl.DateTimeFormat('fr-FR', tOpts).format(debut);
  if (fin && fin.toDateString() === debut.toDateString()) {
    const h2 = new Intl.DateTimeFormat('fr-FR', tOpts).format(fin);
    return `${d}, ${h1}–${h2}`;
  }
  return `${d}, ${h1}`;
}
---

<Layout
  title={hasContent && page ? page.data.title : fallbackTitle}
  description={hasContent && page ? page.data.description : undefined}
  ogSlug={page?.id ?? 'agenda'}
  jsonLd={eventSchemas}
>
  {page?.data.hero ? <Hero {...page.data.hero} /> : <Hero titre={fallbackTitle} variant="violet" />}

  <Section>
    <div
      class="flex flex-col gap-4 rounded-2xl border border-line bg-paper p-6 md:flex-row md:items-center md:justify-between md:p-8"
    >
      <div class="max-w-2xl">
        <h2 class="text-xl font-bold md:text-2xl">S'abonner à l'agenda</h2>
        <p class="mt-2 text-sm leading-relaxed md:text-base">
          Ajoutez l'agenda complet à votre calendrier (Apple, Google, Outlook,
          Thunderbird). Les nouveaux événements apparaîtront automatiquement,
          sans revenir sur le site.
        </p>
      </div>
      <div class="flex flex-col items-start gap-2 md:items-end">
        <a
          href={feedWebcal}
          class="inline-flex items-center gap-2 rounded-full bg-orange px-5 py-2 text-sm font-bold text-paper hover:opacity-85"
        >
          S'abonner
        </a>
        <a
          href={feedHttps}
          class="text-xs text-ink/60 underline-offset-2 hover:text-orange hover:underline"
        >
          ou copier le lien direct
        </a>
      </div>
    </div>
  </Section>

  <Section titre="À venir">
    {
      aVenir.length === 0 ? (
        <p class="text-sm opacity-70">
          Aucun événement programmé pour l'instant. Restez en lien par email.
        </p>
      ) : (
        <>
          {hasFictive ? (
            <Draft reason="Événements fictifs — à remplacer par les vrais via le CMS">
              <ul class="grid gap-4 md:grid-cols-2">
                {aVenir.map((e) => (
                  <li class="rounded-xl border border-line bg-paper p-6">
                    <DraftBadge draft={e.data.draft} />
                    <p class="text-xs font-semibold uppercase tracking-wide text-orange">
                      {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
                    </p>
                    <h2 class="mt-2 mb-1 text-xl font-bold">{e.data.title}</h2>
                    <div class="mb-3 flex flex-wrap gap-2 text-xs">
                      <span class="rounded-full bg-cream px-3 py-1">
                        {e.data.public}
                      </span>
                      {e.data.gratuit && (
                        <span class="rounded-full bg-moss text-paper px-3 py-1">Gratuit</span>
                      )}
                    </div>
                    <div class="text-sm leading-relaxed" set:html={e.bodyHtml} />
                    <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
                      {e.data.inscription_url && (
                        <a
                          href={e.data.inscription_url}
                          class="font-semibold text-orange hover:underline"
                        >
                          S'inscrire / en savoir plus →
                        </a>
                      )}
                      <a
                        href={`/agenda/${e.id}.ics`}
                        download
                        class="text-sm text-ink/70 underline-offset-2 hover:text-orange hover:underline"
                      >
                        Ajouter à mon agenda
                      </a>
                    </div>
                  </li>
                ))}
              </ul>
            </Draft>
          ) : (
            <ul class="grid gap-4 md:grid-cols-2">
              {aVenir.map((e) => (
                <li class="rounded-xl border border-line bg-paper p-6">
                  <p class="text-xs font-semibold uppercase tracking-wide text-orange">
                    {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
                  </p>
                  <h2 class="mt-2 mb-1 text-xl font-bold">{e.data.title}</h2>
                  <div class="mb-3 flex flex-wrap gap-2 text-xs">
                    <span class="rounded-full bg-cream px-3 py-1">{e.data.public}</span>
                    {e.data.gratuit && (
                      <span class="rounded-full bg-moss text-paper px-3 py-1">Gratuit</span>
                    )}
                  </div>
                  <div class="text-sm leading-relaxed" set:html={e.bodyHtml} />
                  <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
                    {e.data.inscription_url && (
                      <a
                        href={e.data.inscription_url}
                        class="font-semibold text-orange hover:underline"
                      >
                        S'inscrire / en savoir plus →
                      </a>
                    )}
                    <a
                      href={`/agenda/${e.id}.ics`}
                      download
                      class="text-sm text-ink/70 underline-offset-2 hover:text-orange hover:underline"
                    >
                      Ajouter à mon agenda
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </>
      )
    }
  </Section>

  {
    passes.length > 0 && (
      <Section titre="Événements passés" fond="beige">
        <ul class="grid gap-3 md:grid-cols-2">
          {passes.map((e) => (
            <li class="rounded-lg bg-paper p-4 opacity-80">
              <DraftBadge draft={e.data.draft} />
              <p class="text-xs uppercase tracking-wide text-violet">
                {formatDateFull(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
              </p>
              <p class="mt-1 font-semibold">{e.data.title}</p>
            </li>
          ))}
        </ul>
      </Section>
    )
  }

  <Section>
    <Prose>
      <p class="text-sm opacity-70">
        <em>
          Audrey peut ajouter, modifier et retirer les événements directement depuis
          l'admin du site — sans passer par le code.
        </em>
      </p>
    </Prose>
  </Section>
</Layout>
