---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Prose from '../components/Prose.astro';

const events = (await getCollection('evenements')).sort(
  (a, b) => a.data.date_debut.valueOf() - b.data.date_debut.valueOf(),
);
const now = new Date();
const aVenir = events.filter((e) => e.data.date_debut >= now);
const passes = events
  .filter((e) => e.data.date_debut < now)
  .sort((a, b) => b.data.date_debut.valueOf() - a.data.date_debut.valueOf());

function formatDate(debut: Date, fin?: Date): string {
  const fmt = new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
  const time = new Intl.DateTimeFormat('fr-FR', { hour: '2-digit', minute: '2-digit' });
  const base = `${fmt.format(debut)}, ${time.format(debut)}`;
  if (fin) return `${base}–${time.format(fin)}`;
  return base;
}
---

<Layout
  title="Agenda"
  description="Ateliers, apéros bénévoles, formations, conférences — retrouvez 2mains de femmes."
>
  <Hero
    titre="Agenda"
    accroche="Ateliers découverte, apéros bénévoles, formations, conférences-débats. Certains événements sont ouverts à toutes et tous, d'autres réservés à nos publics."
    variant="beige"
  />

  <Section titre="À venir">
    {
      aVenir.length === 0 ? (
        <p class="text-sm opacity-70">
          Aucun événement programmé pour l'instant. Restez en lien par email.
        </p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {aVenir.map(async (e) => {
            const { Content } = await render(e);
            return (
              <li class="rounded-xl border border-beige bg-paper p-6">
                <p class="text-xs font-semibold uppercase tracking-wide text-orange">
                  {formatDate(e.data.date_debut, e.data.date_fin)} · {e.data.lieu}
                </p>
                <h2 class="mt-2 mb-1 text-xl font-bold">{e.data.title}</h2>
                <div class="mb-3 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-beige px-3 py-1">{e.data.public}</span>
                  {e.data.gratuit && (
                    <span class="rounded-full bg-vert px-3 py-1">Gratuit</span>
                  )}
                </div>
                <div class="text-sm leading-relaxed">
                  <Content />
                </div>
                {e.data.inscription_url && (
                  <p class="mt-4">
                    <a
                      href={e.data.inscription_url}
                      class="font-semibold text-orange hover:underline"
                    >
                      S'inscrire / en savoir plus →
                    </a>
                  </p>
                )}
              </li>
            );
          })}
        </ul>
      )
    }
  </Section>

  {
    passes.length > 0 && (
      <Section titre="Événements passés" fond="beige">
        <ul class="grid gap-3 md:grid-cols-2">
          {passes.map((e) => (
            <li class="rounded-lg bg-paper p-4 opacity-80">
              <p class="text-xs uppercase tracking-wide text-violet">
                {formatDate(e.data.date_debut)} · {e.data.lieu}
              </p>
              <p class="mt-1 font-semibold">{e.data.title}</p>
            </li>
          ))}
        </ul>
      </Section>
    )
  }

  <Section>
    <Prose>
      <p class="text-sm opacity-70">
        <em>
          Agenda géré directement via le CMS : Audrey peut ajouter, modifier ou retirer
          les événements depuis l'admin (<a href="/admin/">/admin/</a>) sans passer par le
          code.
        </em>
      </p>
    </Prose>
  </Section>
</Layout>
