---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import { site } from '../../config/site';
---

<Layout
  title="Mécénat d'entreprise"
  description="Votre entreprise peut soutenir 2mains de femmes par du mécénat financier, en nature ou en compétences. Défiscalisation à 60 %."
>
  <Hero
    titre="Mécénat d'entreprise"
    sousTitre="Nous soutenir"
    accroche="Associez votre entreprise à un projet d'innovation sociale qui touche à la santé mentale, au lien social et à l'égalité de genre."
    variant="vert"
    ctaPrimaire={{ label: 'Prendre contact', href: '/contact' }}
  />

  <Section titre="Trois formes de mécénat">
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: 'Mécénat financier',
          description:
            "Un don ponctuel ou récurrent. Défiscalisable à 60 % dans la limite de 0,5 % du chiffre d'affaires. Reçu fiscal automatique. À partir de 500 €.",
          couleur: 'orange',
        },
        {
          titre: 'Mécénat en nature',
          description:
            "Mise à disposition de locaux, de matériel (tables de massage, coussins, huiles…), ou de produits. Valorisable et défiscalisable.",
          couleur: 'violet',
        },
        {
          titre: 'Mécénat de compétences',
          description:
            "Vos salarié·es offrent une partie de leur temps de travail (communication, compta, juridique, design, tech…). Défiscalisable au coût chargé.",
          couleur: 'magenta',
        },
      ]}
    />
  </Section>

  <Section titre="Ce que nous vous offrons en retour" fond="beige">
    <Prose>
      <ul>
        <li>
          <strong>Reçu fiscal</strong> automatique pour chaque don.
        </li>
        <li>
          <strong>Convention de mécénat</strong> claire, avec engagements réciproques écrits.
        </li>
        <li>
          <strong>Bilan annuel d'utilisation</strong> des fonds, avec indicateurs d'impact.
        </li>
        <li>
          <strong>Visibilité</strong> (selon votre souhait) : logo sur le site, citation
          dans le rapport d'activité, invitations à nos événements.
        </li>
        <li>
          <strong>Rencontres de terrain</strong> avec l'équipe et, sur accord, avec des
          participantes volontaires.
        </li>
        <li>
          <strong>Ateliers sur mesure</strong> pour vos collaborateur·ices — tarifs préférentiels.
        </li>
      </ul>
    </Prose>
  </Section>

  <Section titre="À qui s'adresse notre mécénat ?">
    <Prose>
      <p>
        Nous travaillons avec des entreprises dont les valeurs sont compatibles avec les
        nôtres. Nous refusons les secteurs dont l'activité entre en contradiction directe
        avec notre mission (armes, alcool/tabac, jeux d'argent, contenus pornographiques,
        industries prédatrices, etc.).
      </p>
      <p>
        Taille, secteur, chiffre d'affaires : peu importe. Ce qui compte, c'est la qualité
        de la relation qu'on construit.
      </p>
    </Prose>
  </Section>

  <Section fond="vert">
    <Prose>
      <h2>Parlons-en autour d'un café</h2>
      <p>
        Un premier échange informel, sans engagement. Écrivez-nous à
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a> ou via le
        formulaire de contact.
      </p>
      <p>
        <a href="/contact">Prendre contact →</a>
      </p>
    </Prose>
  </Section>
</Layout>
