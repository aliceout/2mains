---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import Prose from '../../components/Prose.astro';
import { site } from '../../config/site';
---

<Layout
  title="Nous soutenir"
  description="Dons, adhésions, mécénat — plusieurs manières de soutenir 2mains de femmes."
>
  <Hero
    titre="Nous soutenir"
    accroche="75 adhérent·es et une centaine de soutiens individuels nous permettent déjà d'exister. Votre soutien rend possible l'accompagnement gratuit des femmes les plus vulnérables."
    variant="magenta"
    ctaPrimaire={{ label: 'Faire un don', href: site.helloasso.don, externe: true }}
    ctaSecondaire={{ label: 'Adhérer', href: site.helloasso.adhesion, externe: true }}
  />

  <Section>
    <BlocCartes
      colonnes={3}
      cartes={[
        {
          titre: 'Faire un don',
          description:
            "Un don ponctuel ou mensuel via HelloAsso. Montant libre, déductible à 66 % de l'impôt sur le revenu.",
          href: '/soutenir/dons',
          cta: 'En savoir plus',
          couleur: 'orange',
        },
        {
          titre: 'Adhérer',
          description:
            "Adhésion à prix libre — rejoignez les 75 adhérent·es qui soutiennent l'association et participent à l'AG.",
          href: site.helloasso.adhesion,
          cta: 'Adhérer sur HelloAsso',
          couleur: 'violet',
        },
        {
          titre: 'Mécénat entreprise',
          description:
            "Votre entreprise peut nous soutenir financièrement, en nature, ou en compétences. Défiscalisable à 60 %.",
          href: '/soutenir/mecenat',
          cta: 'Découvrir',
          couleur: 'vert',
        },
      ]}
    />
  </Section>

  <Section titre="À quoi ça sert, concrètement ?" fond="beige">
    <Prose>
      <p>Vos soutiens financent :</p>
      <ul>
        <li>le matériel des séances (tables, coussins, huiles, paravents…) ;</li>
        <li>les déplacements de nos intervenant·es entre les structures ;</li>
        <li>la formation et la supervision des bénévoles ;</li>
        <li>l'ingénierie des parcours (méthodologie, outils d'évaluation) ;</li>
        <li>notre travail de documentation et de plaidoyer.</li>
      </ul>
      <p>
        Pour aller plus loin, voir notre <a href="/association/documents">rapport
        d'activité</a> (à paraître).
      </p>
    </Prose>
  </Section>
</Layout>
