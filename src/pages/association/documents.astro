---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import DraftBadge from '../../components/DraftBadge.astro';
import { filterPublished } from '../../lib/drafts';

const page = await getEntry('pages', 'documents');
if (!page) throw new Error('content/pages/documents.md introuvable');

const docs = filterPublished(await getCollection('documents')).sort((a, b) => {
  if (a.data.a_paraitre !== b.data.a_paraitre) return a.data.a_paraitre ? 1 : -1;
  const da = a.data.date?.valueOf() ?? 0;
  const db = b.data.date?.valueOf() ?? 0;
  return db - da;
});

function formatDate(d: Date | undefined): string {
  if (!d) return 'À paraître';
  return new Intl.DateTimeFormat('fr-FR', { month: 'long', year: 'numeric' }).format(d);
}
---

<Layout title={page.data.title} description={page.data.description} ogSlug={page.id}>
  {page.data.hero && <Hero {...page.data.hero} />}

  <Section>
    <ul class="grid gap-4 md:grid-cols-2">
      {
        docs.map((d) => (
          <li class="flex flex-col rounded-xl border border-beige bg-paper p-6">
            <DraftBadge draft={d.data.draft} />
            <p class="text-xs font-semibold tracking-wide uppercase text-violet">
              {d.data.categorie} · {formatDate(d.data.date)}
            </p>
            <h2 class="mt-2 mb-2 text-xl font-bold">{d.data.titre}</h2>
            {d.data.description_courte && (
              <p class="mb-4 flex-1 text-sm leading-relaxed">
                {d.data.description_courte}
              </p>
            )}
            {d.data.a_paraitre ? (
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-beige px-4 py-2 text-sm font-semibold opacity-70">
                À paraître
              </span>
            ) : d.data.fichier ? (
              <a
                href={d.data.fichier}
                class="inline-flex w-fit items-center gap-2 rounded-full bg-orange px-4 py-2 text-sm font-bold text-paper hover:bg-magenta"
              >
                Télécharger le PDF →
              </a>
            ) : (
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-beige px-4 py-2 text-sm font-semibold opacity-70">
                Disponible sur demande
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </Section>
</Layout>
