---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Prose from '../../components/Prose.astro';
import BlocValeurs from '../../components/BlocValeurs.astro';
---

<Layout title="Qui sommes-nous" description="Mission, vision, valeurs de 2mains de femmes.">
  <Hero
    titre="Qui sommes-nous"
    sousTitre="L'association"
    accroche="Notre raison d'être : que toutes les femmes, en particulier les plus isolées, retrouvent un lien apaisé avec leur corps et les autres grâce au toucher relationnel et à la tendresse."
    variant="beige"
  />

  <Section>
    <Prose>
      <h2>Notre mission</h2>
      <p>
        <strong>
          Améliorer la santé, l'insertion sociale et le pouvoir d'agir des femmes en
          promouvant, défendant et mettant en action le toucher relationnel comme réponse à
          l'isolement corporel et social, et comme vecteur de liens sociaux, dans un contexte
          d'inégalités de genre.
        </strong>
      </p>

      <h2>Notre vision</h2>
      <p>
        Nous avons la vision d'<strong>un monde où le toucher et la tendresse sont créateurs de
        liens sociaux équilibrés</strong>, où les femmes se sentent bien dans leur corps et
        dans leur pouvoir d'agir pour <em>faire-société</em>.
      </p>

      <h2>La problématique que nous posons</h2>
      <p>
        Dans un contexte marqué par des inégalités de genre, en quoi le toucher relationnel
        peut-il constituer une réponse efficace à l'isolement corporel et social des femmes, et
        favoriser des relations sociales apaisées ?
      </p>
    </Prose>
  </Section>

  <Section titre="Nos quatre valeurs" fond="beige">
    <BlocValeurs
      valeurs={[
        {
          nom: 'Tendresse',
          description:
            "Réhabiliter la douceur comme puissance d'action. Pour nous, la tendresse est une force : une manière d'accueillir, d'écouter, de ralentir et de créer des conditions de réparation, de confiance et de lien. Elle se vit dans les accompagnements comme dans notre façon de travailler ensemble.",
          couleur: 'orange',
        },
        {
          nom: 'Sororité',
          description:
            "Se reconnaître, s'entraider et se relever entre femmes. La sororité, c'est refuser la solitude imposée et faire place à l'entraide, à la solidarité et à la confiance. Elle guide notre attention à des espaces sécurisés, favorables à la reconnexion au corps, à l'histoire de chacune et au lien avec les autres.",
          couleur: 'magenta',
        },
        {
          nom: 'Souveraineté du corps',
          description:
            "Reprendre pouvoir sur son corps, reprendre pouvoir sur sa vie. Chaque femme est la première experte de son corps. Cette valeur implique consentement, choix, respect des limites et reconnexion aux sensations, pour soutenir dignité, liberté et pouvoir d'agir.",
          couleur: 'violet',
        },
        {
          nom: 'Lien social',
          description:
            "Retisser du commun à partir des corps. Le lien social est à la fois notre valeur, notre démarche et notre finalité. Nous défendons une approche où la co-présence, la confiance et le toucher relationnel contribuent à lutter contre l'isolement corporel et social.",
          couleur: 'vert',
        },
      ]}
    />
  </Section>

  <Section titre="Nos principes d'action">
    <Prose>
      <ul>
        <li>
          <strong>Rendre actrice</strong> — les femmes concernées décident du contenu des
          séances, coconstruisent les ateliers, siègent dans nos instances.
        </li>
        <li>
          <strong>Aller vers</strong> — nous nous déplaçons au plus près des lieux où les
          femmes sont déjà accueillies, plutôt que d'attendre qu'elles viennent.
        </li>
        <li>
          <strong>Innover</strong> — penser et documenter une approche encore marginale en
          France : le toucher relationnel comme outil de lien social.
        </li>
        <li>
          <strong>Coopérer</strong> — avec les associations, les professionnel·les du soin et
          du social, les institutions, les chercheur·ses, les praticien·nes du corps.
        </li>
      </ul>
    </Prose>
  </Section>
</Layout>
