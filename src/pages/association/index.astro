---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import BlocCartes from '../../components/BlocCartes.astro';
import Prose from '../../components/Prose.astro';
---

<Layout title="L'association">
  <Hero
    titre="L'association"
    accroche="Née en 2024 d'un constat de terrain, 2mains de femmes propose une approche qui remet le corps au cœur de l'accompagnement social et relationnel."
    variant="orange"
  />

  <Section>
    <Prose>
      <p class="text-lg">
        Nous agissons auprès de <strong>femmes majeures, qui se sentent ou sont en isolement
        corporel</strong>, notamment les plus vulnérables, pour favoriser une reconnexion à
        leur corps, à elles-mêmes et au toucher des autres.
      </p>
      <p>
        Notre démarche est <strong>non médicalisée</strong>, fondée sur le
        <strong>consentement</strong>, la non-violence, le respect du rythme de chacune, et la
        coopération étroite avec les structures partenaires du social, du médico-social et de
        la santé.
      </p>
    </Prose>
  </Section>

  <Section titre="Pour en savoir plus" fond="beige">
    <BlocCartes
      cartes={[
        {
          titre: 'Qui sommes-nous',
          description: "Mission, vision, valeurs, principes d'action.",
          href: '/association/qui-sommes-nous',
          cta: 'Lire',
          couleur: 'orange',
        },
        {
          titre: 'Nos interventions',
          description: "Les 3 axes et la méthode d'accompagnement.",
          href: '/association/interventions',
          cta: 'Découvrir',
          couleur: 'violet',
        },
        {
          titre: 'Notre équipe',
          description: 'CA, bénévoles, réseau de praticien·nes solidaires.',
          href: '/association/equipe',
          cta: 'Voir',
          couleur: 'magenta',
        },
        {
          titre: 'Nos documents',
          description: 'Projet associatif, rapports, ressources à télécharger.',
          href: '/association/documents',
          cta: 'Télécharger',
          couleur: 'bleu',
        },
        {
          titre: 'Financeurs et partenaires',
          description: 'Les alliances de confiance qui portent le projet.',
          href: '/association/financeurs',
          cta: 'Les lire',
          couleur: 'vert',
        },
      ]}
    />
  </Section>
</Layout>
