---
// Wrapper pour du markdown / HTML riche avec styles lisibles par défaut.
---

<div class="prose-custom max-w-3xl">
  <slot />
</div>

<style>
  .prose-custom :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .prose-custom :global(h2) {
      font-size: 1.875rem;
    }
  }
  .prose-custom :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }
  .prose-custom :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: disc;
  }
  .prose-custom :global(ul li),
  .prose-custom :global(ol li) {
    margin-top: 0.25rem;
  }
  .prose-custom :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: decimal;
  }
  .prose-custom :global(a) {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-custom :global(a:hover) {
    color: var(--color-magenta);
  }
  .prose-custom :global(blockquote) {
    border-left: 4px solid var(--color-violet);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    opacity: 0.9;
  }
  .prose-custom :global(strong) {
    font-weight: 700;
  }
</style>
