---
/**
 * Deux colonnes : un côté texte markdown, l'autre un picto / illustration.
 * Inversable via `inverse=true` pour alterner quand on en empile plusieurs.
 */
import { marked } from 'marked';

type Props = {
  texte: string;
  picto_couleur?: 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu' | 'beige';
  inverse?: boolean;
  image?: string; // chemin public (ex: /uploads/…)
  image_alt?: string;
};

const {
  texte,
  picto_couleur = 'orange',
  inverse = false,
  image,
  image_alt,
} = Astro.props;

const html = marked.parse(texte, { async: false }) as string;

const pictoFill = {
  orange: '#EC6A2C',
  violet: '#695EA3',
  magenta: '#DD057E',
  vert: '#A2D1B0',
  bleu: '#00607E',
  beige: '#F9E8D8',
}[picto_couleur];
---

<div
  class:list={[
    'grid items-center gap-8 md:grid-cols-2',
    inverse && 'md:[&>*:first-child]:order-2',
  ]}
>
  <div class="flex justify-center">
    {
      image ? (
        <img
          src={image}
          alt={image_alt ?? ''}
          class="max-h-80 w-auto rounded-xl object-contain"
        />
      ) : (
        <div
          class="flex h-48 w-48 items-center justify-center rounded-full md:h-64 md:w-64"
          style={`background: ${pictoFill}22`}
          aria-hidden="true"
        >
          <img
            src="/brand/picto.svg"
            alt=""
            class="h-32 w-32 md:h-40 md:w-40"
            style={`filter: drop-shadow(0 0 0 ${pictoFill})`}
          />
        </div>
      )
    }
  </div>
  <div class="prose-custom max-w-none">
    <Fragment set:html={html} />
  </div>
</div>

<style>
  .prose-custom :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin-top: 0;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .prose-custom :global(h2) {
      font-size: 1.875rem;
    }
  }
  .prose-custom :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-custom :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }
  .prose-custom :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: disc;
  }
  .prose-custom :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: decimal;
  }
  .prose-custom :global(a) {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-custom :global(strong) {
    font-weight: 700;
  }
</style>
