---
// Deux colonnes : texte markdown d'un côté + picto/illustration de
// l'autre. Le picto est un blob organique coloré (signature visuelle
// du design) qu'on peut remplacer par une image réelle si fournie.
// Inversable via `inverse=true`.
import { renderRichOrMarkdown } from '../lib/lexical';
import Blob from './atoms/Blob.astro';

type Couleur = 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu' | 'beige';

type Props = {
  /** Texte markdown legacy. */
  texte?: string;
  /** Texte Lexical (nouveau richText). Si rempli, écrase texte. */
  texte_rich?: unknown;
  picto_couleur?: Couleur;
  inverse?: boolean;
  image?: string; // chemin public (ex: /uploads/…)
  image_alt?: string;
};

const {
  texte,
  texte_rich,
  picto_couleur = 'orange',
  inverse = false,
  image,
  image_alt,
} = Astro.props;

const html = renderRichOrMarkdown(texte_rich, texte);

// Mapping couleur historique → couleur de blob (palette élargie).
const blobColor: Record<Couleur, 'orange' | 'violet' | 'rose' | 'moss' | 'mauve' | 'peach'> = {
  orange: 'orange',
  violet: 'violet',
  magenta: 'rose',
  vert: 'moss',
  bleu: 'mauve',
  beige: 'peach',
};
---

<div
  class:list={[
    'grid items-center gap-10 md:grid-cols-2 md:gap-16',
    inverse && 'md:[&>*:first-child]:order-2',
  ]}
>
  <div class="flex justify-center">
    {image ? (
      <img
        src={image}
        alt={image_alt ?? ''}
        class="max-h-100 w-auto rounded-2xl object-cover"
      />
    ) : (
      <div class="relative aspect-square w-full max-w-90">
        <Blob
          size={360}
          color={blobColor[picto_couleur]}
          seed={picto_couleur.length}
          opacity={0.55}
          class="absolute inset-0 h-full w-full"
        />
        <Blob
          size={120}
          color={blobColor[picto_couleur]}
          seed={(picto_couleur.length + 2) % 5}
          opacity={0.85}
          class="absolute right-8 bottom-8 h-30 w-30"
        />
      </div>
    )}
  </div>
  <div class="deux-col-prose max-w-[55ch]">
    <Fragment set:html={html} />
  </div>
</div>

<style>
  .deux-col-prose {
    font-family: var(--font-sans);
    color: var(--color-ink-2);
    line-height: 1.65;
  }
  .deux-col-prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }
  @media (min-width: 768px) {
    .deux-col-prose :global(h2) {
      font-size: 28px;
    }
  }
  .deux-col-prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 500;
    margin: 1.25rem 0 0.5rem;
    color: var(--color-ink);
  }
  @media (min-width: 768px) {
    .deux-col-prose :global(h3) {
      font-size: 21px;
    }
  }
  .deux-col-prose :global(p) {
    font-size: 16px;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .deux-col-prose :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: disc;
  }
  .deux-col-prose :global(strong) {
    font-weight: 500;
    color: var(--color-ink);
  }
  .deux-col-prose :global(em) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    color: var(--color-orange);
  }
  .deux-col-prose :global(a) {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
