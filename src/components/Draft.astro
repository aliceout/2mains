---
// <Draft reason="..."> — marque visuellement un contenu inventé /
// provisoire. Bordure orange pointillée + ruban "À VALIDER" mono
// uppercase en haut à droite. Toujours visible (prod comme dev) pour
// qu'Audrey voie ce qui reste à valider. `hide` true masque le ruban
// (utile pour wrapper tout en gardant le contenu).
type Props = {
  reason: string;
  hide?: boolean;
};

const { reason, hide = false } = Astro.props;
---

{
  hide ? (
    <slot />
  ) : (
    <div class="draft-marker" data-draft={reason}>
      <span class="draft-marker__tag" aria-label={`À valider : ${reason}`}>
        À valider · {reason}
      </span>
      <slot />
    </div>
  )
}

<style>
  .draft-marker {
    position: relative;
    border: 2px dashed var(--color-orange);
    border-radius: 14px;
    padding: 1rem;
    margin: 0.5rem 0;
  }

  .draft-marker__tag {
    position: absolute;
    top: -0.7rem;
    right: 1rem;
    background: var(--color-orange);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 9999px;
    z-index: 1;
    pointer-events: none;
    max-width: calc(100% - 2rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: no-preference) {
    .draft-marker__tag {
      animation: draft-pulse 2.4s ease-in-out infinite;
    }
  }

  @keyframes draft-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.75;
    }
  }
</style>
