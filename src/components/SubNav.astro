---
// Sous-navigation horizontale qui apparaît quand on est dans une catégorie
// ayant des enfants. Option 1 validée par Audrey (chat 17/10) : naviguer
// vers une page de catégorie affiche la nav secondaire, on clique sur un
// enfant on arrive sur la sous-page en gardant la même nav secondaire
// visible.
import { getCurrentCategory } from '../lib/site';

const path = Astro.url.pathname;
const category = getCurrentCategory(path);

function isCurrent(href: string | undefined): boolean {
  if (!href) return false;
  const clean = path.replace(/\/$/, '') || '/';
  return clean === href || clean.startsWith(href + '/');
}
---

{
  category?.children && category.children.length > 0 && (
    <nav
      aria-label={`Sections de ${category.label}`}
      class="border-b border-beige bg-paper/90"
    >
      <ul class="mx-auto flex max-w-6xl flex-wrap items-center gap-1 px-4 py-2 text-sm">
        <li class="pr-2 text-xs font-bold uppercase tracking-wide text-ink/50">
          {category.label}
        </li>
        {category.children.map((child) => {
          const current = isCurrent(child.href);
          return (
            <li>
              <a
                href={child.href}
                aria-current={current ? 'page' : undefined}
                class:list={[
                  'rounded px-3 py-1.5 transition-colors hover:text-orange',
                  current ? 'bg-beige text-orange font-semibold' : 'text-ink',
                ]}
              >
                {child.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  )
}
