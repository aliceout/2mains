---
// Sommaire ancré pour pages longues. Sticky sur écran XL, IntersectionObserver
// pour marquer la section visible. Visuel refondu : eyebrow mono uppercase,
// liens en italique serif fine, item actif orange + bg cream.
type Item = { id: string; label: string };
type Props = { items: Item[] };

const { items } = Astro.props;
---

{
  items.length >= 2 && (
    <aside
      data-toc
      aria-label="Sommaire"
      class="hidden xl:block fixed right-6 top-28 z-30 w-60 max-h-[calc(100vh-9rem)] overflow-auto rounded-xl border border-line bg-paper/95 p-5 backdrop-blur"
    >
      <p
        class="mb-3 font-mono text-[11px] uppercase text-ink-3"
        style="letter-spacing: 0.12em;"
      >
        — Sur cette page
      </p>
      <nav>
        <ul class="space-y-1">
          {items.map((i) => (
            <li>
              <a
                href={`#${i.id}`}
                class="block rounded px-2 py-1.5 font-serif text-[15px] italic text-ink-2 transition-colors hover:bg-cream hover:text-orange"
                data-toc-link={i.id}
              >
                {i.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length > 0) {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => {
      const id = a.getAttribute('data-toc-link');
      if (id) byId.set(id, a);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = byId.get(entry.target.id);
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach((a) =>
              a.classList.remove('bg-cream', 'text-orange', 'font-medium'),
            );
            link.classList.add('bg-cream', 'text-orange', 'font-medium');
          }
        });
      },
      { rootMargin: '-30% 0px -60% 0px' },
    );

    byId.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
