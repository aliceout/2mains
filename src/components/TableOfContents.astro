---
type Item = { id: string; label: string };
type Props = { items: Item[] };

const { items } = Astro.props;
---

{
  items.length >= 2 && (
    <aside
      data-toc
      aria-label="Sommaire"
      class="hidden xl:block fixed right-6 top-24 z-30 w-56 max-h-[calc(100vh-8rem)] overflow-auto rounded-lg border border-beige bg-paper/95 p-4 text-sm shadow-sm backdrop-blur"
    >
      <p class="mb-2 text-xs font-bold uppercase tracking-wide text-ink/60">
        Sur cette page
      </p>
      <nav>
        <ul class="space-y-1">
          {items.map((i) => (
            <li>
              <a
                href={`#${i.id}`}
                class="block rounded px-2 py-1 text-ink/80 transition-colors hover:bg-beige hover:text-orange"
                data-toc-link={i.id}
              >
                {i.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length > 0) {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => {
      const id = a.getAttribute('data-toc-link');
      if (id) byId.set(id, a);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = byId.get(entry.target.id);
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach((a) =>
              a.classList.remove('bg-beige', 'font-semibold', 'text-orange'),
            );
            link.classList.add('bg-beige', 'font-semibold', 'text-orange');
          }
        });
      },
      { rootMargin: '-30% 0px -60% 0px' },
    );

    byId.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
