---
// Wrapper image utilisé par tous les blocs. Si le manifest d'images
// optimisées (scripts/optimize-images.mjs) contient une entrée pour
// le src donné, on émet un <picture> avec sources AVIF + WebP en
// srcset + fallback <img>. Sinon on rend juste un <img> avec les
// défauts sains (lazy, decoding async).
import manifest from '../data/image-manifest.json';

type Variant = { width: number; path: string };
type ManifestEntry = {
  original: string;
  width: number;
  height: number;
  variants: { avif: Variant[]; webp: Variant[] };
};
const manifestMap = manifest as Record<string, ManifestEntry>;

type Props = {
  src: string;
  alt: string;
  fit?: 'cover' | 'contain';
  width?: number;
  height?: number;
  class?: string;
  eager?: boolean;
  /** Hint sur la taille affichée pour que le navigateur choisisse la
   *  bonne variante de srcset. Exemples : "50vw", "(min-width: 768px) 33vw, 100vw".
   *  Par défaut "100vw" (image pleine largeur). */
  sizes?: string;
};

const {
  src,
  alt,
  fit = 'cover',
  width,
  height,
  class: className,
  eager = false,
  sizes = '100vw',
} = Astro.props;

const entry = !src.startsWith('http') && !src.endsWith('.svg')
  ? manifestMap[src] ?? null
  : null;

function srcsetFor(variants: Variant[]): string {
  return variants.map((v) => `${v.path} ${v.width}w`).join(', ');
}

const imgClass = [
  fit === 'cover' ? 'object-cover' : 'object-contain',
  className,
];
const w = width ?? entry?.width;
const h = height ?? entry?.height;
---

{
  entry ? (
    <picture>
      <source
        type="image/avif"
        srcset={srcsetFor(entry.variants.avif)}
        sizes={sizes}
      />
      <source
        type="image/webp"
        srcset={srcsetFor(entry.variants.webp)}
        sizes={sizes}
      />
      <img
        src={src}
        alt={alt}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width={w}
        height={h}
        class:list={imgClass}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width={w}
      height={h}
      class:list={imgClass}
    />
  )
}
