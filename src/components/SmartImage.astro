---
// Wrapper image — surcouche minimale au-dessus de <img>.
//
// À l'origine ce composant gérait deux pipelines pré-build (download
// Unsplash + génération AVIF/WebP multi-tailles) sur les fichiers
// statiques de public/uploads/. Avec la migration vers Payload, les
// uploads vivent côté CMS et leurs URLs sont externes — plus aucune
// transformation côté Astro. On garde le wrapper pour normaliser
// loading/decoding/fit sur tout le site.

type Props = {
  src: string;
  alt: string;
  fit?: 'cover' | 'contain';
  width?: number;
  height?: number;
  class?: string;
  eager?: boolean;
  /** Attribut `sizes` HTML — ignoré ici (pas de srcset), conservé
   *  pour compat de l'API d'appel des composants existants. */
  sizes?: string;
};

const {
  src,
  alt,
  fit = 'cover',
  width,
  height,
  class: className,
  eager = false,
} = Astro.props;

const imgClass = [
  fit === 'cover' ? 'object-cover' : 'object-contain',
  className,
];
---

<img
  src={src}
  alt={alt}
  loading={eager ? 'eager' : 'lazy'}
  decoding="async"
  width={width}
  height={height}
  class:list={imgClass}
/>
