---
import { marked } from 'marked';
import { filterPublished } from '../lib/drafts';
import { fetchCollectionLegacy, type LegacyPage } from '../lib/payload';
import Hero from './Hero.astro';
import Section from './Section.astro';
import Prose from './Prose.astro';
import BlocCartes from './BlocCartes.astro';
import BlocValeurs from './BlocValeurs.astro';
import BlocStat from './BlocStat.astro';
import BlocCitation from './BlocCitation.astro';
import Etapes from './Etapes.astro';
import DeuxColonnes from './DeuxColonnes.astro';
import Faq from './Faq.astro';
import Callout from './Callout.astro';
import ChiffreDetail from './ChiffreDetail.astro';
import Formats from './Formats.astro';
import CitationLarge from './CitationLarge.astro';
import TextePhoto from './TextePhoto.astro';
import Figure from './Figure.astro';
import Galerie from './Galerie.astro';
import BandeauImage from './BandeauImage.astro';
import Portraits from './Portraits.astro';
import Timeline from './Timeline.astro';
import Lettre from './Lettre.astro';
import StatMajeste from './StatMajeste.astro';
import Temoignages from './Temoignages.astro';
import Draft from './Draft.astro';

type Props = {
  page: LegacyPage;
};

const { page } = Astro.props;
const { hero, sections } = page.data;

// Si l'une des sections est de type `equipe`, on charge la collection
// pour la rendre en portraits.
const needsEquipe = sections.some((s) => s.type === 'equipe');
const equipeMembres = needsEquipe
  ? filterPublished(
      await fetchCollectionLegacy<{
        nom: string;
        role: string;
        photo?: string;
        bio_courte?: string;
        linkedin?: string;
        ordre?: number;
        draft?: boolean;
      }>('equipe', { sort: 'ordre' }),
    )
  : [];

// Idem pour les témoignages.
const needsTemoignages = sections.some((s) => s.type === 'temoignages');
const tousTemoignages = needsTemoignages
  ? filterPublished(
      await fetchCollectionLegacy<{
        auteur: string;
        role?: string;
        contexte: string;
        photo?: string;
        citation: string;
        ordre?: number;
        a_la_une?: boolean;
        fictif?: boolean;
        draft?: boolean;
      }>('temoignages', { sort: 'ordre' }),
    )
  : [];

function slugify(s: string): string {
  return s
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{Diacritic}/gu, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const sectionIds: (string | undefined)[] = [];
const used = new Set<string>();
for (const s of sections) {
  const t = 'titre' in s ? s.titre : undefined;
  if (!t) {
    sectionIds.push(undefined);
    continue;
  }
  let base = slugify(t);
  let id = base;
  let n = 2;
  while (used.has(id)) id = `${base}-${n++}`;
  used.add(id);
  sectionIds.push(id);
}
---

{hero && <Hero {...hero} />}

{
  sections.map((s, i) => {
    const id = sectionIds[i];
    if (s.type === 'prose') {
      const html = marked.parse(s.body, { async: false }) as string;
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Prose>
            <Fragment set:html={html} />
          </Prose>
        </Section>
      );
    }
    if (s.type === 'cartes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <BlocCartes cartes={s.cartes} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'valeurs') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <BlocValeurs valeurs={s.valeurs} />
        </Section>
      );
    }
    if (s.type === 'stats') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          {s.intro && (
            <div class="mb-8 max-w-3xl">
              <p class="text-lg leading-relaxed">{s.intro}</p>
            </div>
          )}
          <BlocStat stats={s.stats} />
        </Section>
      );
    }
    if (s.type === 'citation') {
      const inner = (
        <BlocCitation
          citation={s.citation}
          auteur={s.auteur}
          role={s.role}
          variant={s.variant}
        />
      );
      return (
        <Section id={id} fond={s.fond}>
          {s.fictif ? (
            <Draft reason={`Citation fictive — ${s.auteur}`}>{inner}</Draft>
          ) : (
            inner
          )}
        </Section>
      );
    }
    if (s.type === 'cta') {
      const isDark = (s.fond ?? 'violet') === 'violet' || (s.fond ?? 'violet') === 'orange' || s.fond === 'vert';
      const titreColor = isDark ? 'text-paper' : 'text-ink';
      const corpsColor = isDark ? 'text-paper/85' : 'text-ink-2';
      return (
        <Section id={id} fond={s.fond ?? 'violet'}>
          <div class="grid gap-6 max-w-225">
            <h2 class:list={['font-serif text-[26px] font-normal leading-tight tracking-tight md:text-[32px]', titreColor]}>
              {s.titre}
            </h2>
            {s.corps && (
              <p class:list={['font-sans text-base leading-relaxed max-w-220', corpsColor]}>{s.corps}</p>
            )}
            {(s.cta_primaire?.label || s.cta_secondaire?.label) && (
              <div class="mt-2 flex flex-wrap items-center gap-3">
                {s.cta_primaire?.label && (
                  isDark ? (
                    <a
                      href={s.cta_primaire.href}
                      target={s.cta_primaire.externe ? '_blank' : undefined}
                      rel={s.cta_primaire.externe ? 'noopener' : undefined}
                      class="inline-flex items-center gap-1.5 rounded-md bg-paper px-5.5 py-3 font-sans text-sm font-medium text-ink no-underline transition-opacity hover:opacity-85"
                    >
                      {s.cta_primaire.label} <span aria-hidden="true">→</span>
                    </a>
                  ) : (
                    <a
                      href={s.cta_primaire.href}
                      target={s.cta_primaire.externe ? '_blank' : undefined}
                      rel={s.cta_primaire.externe ? 'noopener' : undefined}
                      class="inline-flex items-center gap-1.5 rounded-md bg-orange px-5.5 py-3 font-sans text-sm font-medium text-paper no-underline transition-opacity hover:opacity-85"
                    >
                      {s.cta_primaire.label} <span aria-hidden="true">→</span>
                    </a>
                  )
                )}
                {s.cta_secondaire?.label && (
                  <a
                    href={s.cta_secondaire.href}
                    target={s.cta_secondaire.externe ? '_blank' : undefined}
                    rel={s.cta_secondaire.externe ? 'noopener' : undefined}
                    class:list={[
                      'inline-flex items-center gap-1.5 rounded-md border px-5.5 py-3 font-sans text-sm font-medium no-underline transition-opacity hover:opacity-85',
                      isDark ? 'border-paper text-paper bg-transparent' : 'border-ink text-ink bg-transparent',
                    ]}
                  >
                    {s.cta_secondaire.label}
                  </a>
                )}
              </div>
            )}
          </div>
        </Section>
      );
    }
    if (s.type === 'etapes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Etapes etapes={s.etapes} couleur={s.couleur ?? undefined} />
        </Section>
      );
    }
    if (s.type === 'deux-colonnes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <DeuxColonnes
            texte={s.texte}
            inverse={s.inverse}
            picto_couleur={s.picto_couleur}
            image={s.image}
            image_alt={s.image_alt}
          />
        </Section>
      );
    }
    if (s.type === 'faq') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Faq questions={s.questions} />
        </Section>
      );
    }
    if (s.type === 'callout') {
      return (
        <Section id={id} fond={s.fond}>
          <Callout ton={s.ton} titre={s.titre} body={s.body} />
        </Section>
      );
    }
    if (s.type === 'chiffre-detail') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <ChiffreDetail
            chiffre={s.chiffre}
            texte={s.texte}
            source={s.source}
            alignement={s.alignement}
            couleur={s.couleur ?? undefined}
          />
        </Section>
      );
    }
    if (s.type === 'formats') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Formats formats={s.formats} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'citation-large') {
      return (
        <Section id={id} fond={s.fond}>
          <CitationLarge
            citation={s.citation}
            auteur={s.auteur}
            role={s.role}
            variant={s.variant}
          />
        </Section>
      );
    }
    if (s.type === 'texte-photo') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <TextePhoto
            texte={s.texte}
            image={s.image}
            image_alt={s.image_alt}
            image_legende={s.image_legende}
            image_credit={s.image_credit}
            position={s.position}
            ratio={s.ratio}
          />
        </Section>
      );
    }
    if (s.type === 'figure') {
      return (
        <Section id={id} fond={s.fond}>
          <Figure
            image={s.image}
            alt={s.alt}
            legende={s.legende}
            credit={s.credit}
            taille={s.taille}
          />
        </Section>
      );
    }
    if (s.type === 'galerie') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Galerie
            images={s.images}
            colonnes={s.colonnes}
            lightbox={s.lightbox}
          />
        </Section>
      );
    }
    if (s.type === 'bandeau-image') {
      // Rendu hors <Section> pour que l'image soit vraiment pleine largeur.
      return (
        <BandeauImage
          image={s.image}
          alt={s.alt}
          titre={s.titre}
          sousTitre={s.sousTitre}
          hauteur={s.hauteur}
          position_texte={s.position_texte}
          position_verticale={s.position_verticale}
          scrim={s.scrim}
        />
      );
    }
    if (s.type === 'portraits') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Portraits
            personnes={s.personnes}
            colonnes={s.colonnes}
            forme={s.forme}
          />
        </Section>
      );
    }
    if (s.type === 'timeline') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Timeline etapes={s.etapes} alignement={s.alignement} />
        </Section>
      );
    }
    if (s.type === 'temoignages') {
      // `s.ids` = array d'IDs string (relations hasMany normalisées par
      // transformBlock). Vide ou absent → on tire automatiquement
      // depuis la liste complète (respecte filtre `contexte` + limite).
      let subset = s.ids && s.ids.length > 0
        ? tousTemoignages.filter((t) => s.ids!.includes(t.id))
        : tousTemoignages;
      if (s.contexte && !s.ids) {
        subset = subset.filter((t) => t.data.contexte === s.contexte);
      }
      subset = subset.slice(0, s.limite);
      if (subset.length === 0) return null;
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Temoignages temoignages={subset} />
        </Section>
      );
    }
    if (s.type === 'equipe') {
      // `s.ids` = array d'IDs string (relations hasMany normalisées par
      // transformBlock). Vide ou absent → tous les membres (sortés
      // par `ordre`).
      const subset = s.ids && s.ids.length > 0
        ? equipeMembres.filter((m) => s.ids!.includes(m.id))
        : equipeMembres;
      const personnes = subset.map((m) => ({
        nom: m.data.nom,
        role: m.data.role,
        photo: m.data.photo,
        photo_alt: `Portrait de ${m.data.nom}`,
        bio: m.data.bio_courte,
        lien: m.data.linkedin,
        lien_label: m.data.linkedin ? 'LinkedIn' : undefined,
      }));
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          {s.intro && (
            <p class="mb-8 max-w-220 font-sans text-base leading-relaxed text-ink-2">
              {s.intro}
            </p>
          )}
          <Portraits
            personnes={personnes}
            colonnes={s.colonnes}
            forme={s.forme}
          />
        </Section>
      );
    }
    if (s.type === 'lettre') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Lettre
            corps={s.corps}
            ouverture={s.ouverture}
            signature={s.signature}
            variant={s.variant}
          />
        </Section>
      );
    }
    if (s.type === 'stat-majeste') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <StatMajeste
            chiffre={s.chiffre}
            texte={s.texte}
            source={s.source}
            eyebrow={s.eyebrow}
            variant={s.variant}
          />
        </Section>
      );
    }
    return null;
  })
}
