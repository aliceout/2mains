---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { marked } from 'marked';
import Hero from './Hero.astro';
import Section from './Section.astro';
import Prose from './Prose.astro';
import BlocCartes from './BlocCartes.astro';
import BlocValeurs from './BlocValeurs.astro';
import BlocStat from './BlocStat.astro';
import BlocCitation from './BlocCitation.astro';
import Etapes from './Etapes.astro';
import DeuxColonnes from './DeuxColonnes.astro';
import Faq from './Faq.astro';
import Callout from './Callout.astro';
import ChiffreDetail from './ChiffreDetail.astro';
import Formats from './Formats.astro';
import CitationLarge from './CitationLarge.astro';
import Draft from './Draft.astro';

type Props = {
  page: CollectionEntry<'pages'>;
};

const { page } = Astro.props;
const { hero, sections } = page.data;

// Si la page a un corps markdown (hors sections), on le rend en zone prose
// principale. Utile pour les pages très textuelles.
const { Content } = await render(page);
const hasBody = Boolean(page.body && page.body.trim().length > 0);
---

{hero && <Hero {...hero} />}

{
  // Si pas de sections mais du body markdown, on le rend.
  sections.length === 0 && hasBody && (
    <Section>
      <Prose>
        <Content />
      </Prose>
    </Section>
  )
}

{
  sections.map((s) => {
    if (s.type === 'prose') {
      const html = marked.parse(s.body, { async: false }) as string;
      return (
        <Section titre={s.titre} fond={s.fond}>
          <Prose>
            <Fragment set:html={html} />
          </Prose>
        </Section>
      );
    }
    if (s.type === 'cartes') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <BlocCartes cartes={s.cartes} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'valeurs') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <BlocValeurs valeurs={s.valeurs} />
        </Section>
      );
    }
    if (s.type === 'stats') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          {s.intro && (
            <div class="mb-8 max-w-3xl">
              <p class="text-lg leading-relaxed">{s.intro}</p>
            </div>
          )}
          <BlocStat stats={s.stats} />
        </Section>
      );
    }
    if (s.type === 'citation') {
      const inner = (
        <BlocCitation
          citation={s.citation}
          auteur={s.auteur}
          role={s.role}
          variant={s.variant}
        />
      );
      return (
        <Section fond={s.fond}>
          {s.fictif ? (
            <Draft reason={`Citation fictive — ${s.auteur}`}>{inner}</Draft>
          ) : (
            inner
          )}
        </Section>
      );
    }
    if (s.type === 'cta') {
      return (
        <Section fond={s.fond ?? 'violet'}>
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold md:text-4xl">{s.titre}</h2>
            {s.corps && <p class="max-w-3xl text-lg leading-relaxed">{s.corps}</p>}
            {(s.cta_primaire || s.cta_secondaire) && (
              <div class="mt-2 flex flex-wrap gap-3">
                {s.cta_primaire && (
                  <a
                    href={s.cta_primaire.href}
                    target={s.cta_primaire.externe ? '_blank' : undefined}
                    rel={s.cta_primaire.externe ? 'noopener' : undefined}
                    class="rounded-full bg-orange px-6 py-3 font-bold text-paper hover:bg-magenta"
                  >
                    {s.cta_primaire.label}
                  </a>
                )}
                {s.cta_secondaire && (
                  <a
                    href={s.cta_secondaire.href}
                    target={s.cta_secondaire.externe ? '_blank' : undefined}
                    rel={s.cta_secondaire.externe ? 'noopener' : undefined}
                    class="rounded-full border-2 border-current px-6 py-3 font-bold hover:bg-paper/10"
                  >
                    {s.cta_secondaire.label}
                  </a>
                )}
              </div>
            )}
          </div>
        </Section>
      );
    }
    if (s.type === 'etapes') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <Etapes etapes={s.etapes} couleur={s.couleur ?? undefined} />
        </Section>
      );
    }
    if (s.type === 'deux-colonnes') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <DeuxColonnes
            texte={s.texte}
            inverse={s.inverse}
            picto_couleur={s.picto_couleur}
            image={s.image}
            image_alt={s.image_alt}
          />
        </Section>
      );
    }
    if (s.type === 'faq') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <Faq questions={s.questions} />
        </Section>
      );
    }
    if (s.type === 'callout') {
      return (
        <Section fond={s.fond}>
          <Callout ton={s.ton} titre={s.titre} body={s.body} />
        </Section>
      );
    }
    if (s.type === 'chiffre-detail') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <ChiffreDetail
            chiffre={s.chiffre}
            texte={s.texte}
            source={s.source}
            alignement={s.alignement}
            couleur={s.couleur ?? undefined}
          />
        </Section>
      );
    }
    if (s.type === 'formats') {
      return (
        <Section titre={s.titre} fond={s.fond}>
          <Formats formats={s.formats} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'citation-large') {
      return (
        <Section fond={s.fond}>
          <CitationLarge
            citation={s.citation}
            auteur={s.auteur}
            role={s.role}
            variant={s.variant}
          />
        </Section>
      );
    }
    return null;
  })
}
