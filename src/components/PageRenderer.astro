---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { marked } from 'marked';
import Hero from './Hero.astro';
import Section from './Section.astro';
import Prose from './Prose.astro';
import BlocCartes from './BlocCartes.astro';
import BlocValeurs from './BlocValeurs.astro';
import BlocStat from './BlocStat.astro';
import BlocCitation from './BlocCitation.astro';
import Etapes from './Etapes.astro';
import DeuxColonnes from './DeuxColonnes.astro';
import Faq from './Faq.astro';
import Callout from './Callout.astro';
import ChiffreDetail from './ChiffreDetail.astro';
import Formats from './Formats.astro';
import CitationLarge from './CitationLarge.astro';
import TextePhoto from './TextePhoto.astro';
import Figure from './Figure.astro';
import Galerie from './Galerie.astro';
import BandeauImage from './BandeauImage.astro';
import Portraits from './Portraits.astro';
import Timeline from './Timeline.astro';
import Draft from './Draft.astro';
import TableOfContents from './TableOfContents.astro';

type Props = {
  page: CollectionEntry<'pages'>;
};

const { page } = Astro.props;
const { hero, sections, toc } = page.data;

// Si la page a un corps markdown (hors sections), on le rend en zone prose
// principale. Utile pour les pages très textuelles.
const { Content } = await render(page);
const hasBody = Boolean(page.body && page.body.trim().length > 0);

function slugify(s: string): string {
  return s
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{Diacritic}/gu, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

// Calcule un id unique pour chaque section dotée d'un titre, puis construit
// la table des matières.
const sectionIds: (string | undefined)[] = [];
const used = new Set<string>();
for (const s of sections) {
  const t = 'titre' in s ? s.titre : undefined;
  if (!t) {
    sectionIds.push(undefined);
    continue;
  }
  let base = slugify(t);
  let id = base;
  let n = 2;
  while (used.has(id)) id = `${base}-${n++}`;
  used.add(id);
  sectionIds.push(id);
}
const tocItems = sections
  .map((s, i) => {
    const t = 'titre' in s ? s.titre : undefined;
    const id = sectionIds[i];
    if (!t || !id) return null;
    return { id, label: t };
  })
  .filter((x): x is { id: string; label: string } => x !== null);
---

{hero && <Hero {...hero} />}

{toc && tocItems.length >= 2 && <TableOfContents items={tocItems} />}

{
  // Si pas de sections mais du body markdown, on le rend.
  sections.length === 0 && hasBody && (
    <Section>
      <Prose>
        <Content />
      </Prose>
    </Section>
  )
}

{
  sections.map((s, i) => {
    const id = sectionIds[i];
    if (s.type === 'prose') {
      const html = marked.parse(s.body, { async: false }) as string;
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Prose>
            <Fragment set:html={html} />
          </Prose>
        </Section>
      );
    }
    if (s.type === 'cartes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <BlocCartes cartes={s.cartes} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'valeurs') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <BlocValeurs valeurs={s.valeurs} />
        </Section>
      );
    }
    if (s.type === 'stats') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          {s.intro && (
            <div class="mb-8 max-w-3xl">
              <p class="text-lg leading-relaxed">{s.intro}</p>
            </div>
          )}
          <BlocStat stats={s.stats} />
        </Section>
      );
    }
    if (s.type === 'citation') {
      const inner = (
        <BlocCitation
          citation={s.citation}
          auteur={s.auteur}
          role={s.role}
          variant={s.variant}
        />
      );
      return (
        <Section id={id} fond={s.fond}>
          {s.fictif ? (
            <Draft reason={`Citation fictive — ${s.auteur}`}>{inner}</Draft>
          ) : (
            inner
          )}
        </Section>
      );
    }
    if (s.type === 'cta') {
      return (
        <Section id={id} fond={s.fond ?? 'violet'}>
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold md:text-4xl">{s.titre}</h2>
            {s.corps && <p class="max-w-3xl text-lg leading-relaxed">{s.corps}</p>}
            {(s.cta_primaire || s.cta_secondaire) && (
              <div class="mt-2 flex flex-wrap gap-3">
                {s.cta_primaire && (
                  <a
                    href={s.cta_primaire.href}
                    target={s.cta_primaire.externe ? '_blank' : undefined}
                    rel={s.cta_primaire.externe ? 'noopener' : undefined}
                    class="rounded-full bg-orange px-6 py-3 font-bold text-paper hover:bg-magenta"
                  >
                    {s.cta_primaire.label}
                  </a>
                )}
                {s.cta_secondaire && (
                  <a
                    href={s.cta_secondaire.href}
                    target={s.cta_secondaire.externe ? '_blank' : undefined}
                    rel={s.cta_secondaire.externe ? 'noopener' : undefined}
                    class="rounded-full border-2 border-current px-6 py-3 font-bold hover:bg-paper/10"
                  >
                    {s.cta_secondaire.label}
                  </a>
                )}
              </div>
            )}
          </div>
        </Section>
      );
    }
    if (s.type === 'etapes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Etapes etapes={s.etapes} couleur={s.couleur ?? undefined} />
        </Section>
      );
    }
    if (s.type === 'deux-colonnes') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <DeuxColonnes
            texte={s.texte}
            inverse={s.inverse}
            picto_couleur={s.picto_couleur}
            image={s.image}
            image_alt={s.image_alt}
          />
        </Section>
      );
    }
    if (s.type === 'faq') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Faq questions={s.questions} />
        </Section>
      );
    }
    if (s.type === 'callout') {
      return (
        <Section id={id} fond={s.fond}>
          <Callout ton={s.ton} titre={s.titre} body={s.body} />
        </Section>
      );
    }
    if (s.type === 'chiffre-detail') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <ChiffreDetail
            chiffre={s.chiffre}
            texte={s.texte}
            source={s.source}
            alignement={s.alignement}
            couleur={s.couleur ?? undefined}
          />
        </Section>
      );
    }
    if (s.type === 'formats') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Formats formats={s.formats} colonnes={s.colonnes} />
        </Section>
      );
    }
    if (s.type === 'citation-large') {
      return (
        <Section id={id} fond={s.fond}>
          <CitationLarge
            citation={s.citation}
            auteur={s.auteur}
            role={s.role}
            variant={s.variant}
          />
        </Section>
      );
    }
    if (s.type === 'texte-photo') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <TextePhoto
            texte={s.texte}
            image={s.image}
            image_alt={s.image_alt}
            image_legende={s.image_legende}
            image_credit={s.image_credit}
            position={s.position}
            ratio={s.ratio}
          />
        </Section>
      );
    }
    if (s.type === 'figure') {
      return (
        <Section id={id} fond={s.fond}>
          <Figure
            image={s.image}
            alt={s.alt}
            legende={s.legende}
            credit={s.credit}
            taille={s.taille}
          />
        </Section>
      );
    }
    if (s.type === 'galerie') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Galerie
            images={s.images}
            colonnes={s.colonnes}
            lightbox={s.lightbox}
          />
        </Section>
      );
    }
    if (s.type === 'bandeau-image') {
      // Rendu hors <Section> pour que l'image soit vraiment pleine largeur.
      return (
        <BandeauImage
          image={s.image}
          alt={s.alt}
          titre={s.titre}
          sousTitre={s.sousTitre}
          hauteur={s.hauteur}
          position_texte={s.position_texte}
          position_verticale={s.position_verticale}
          scrim={s.scrim}
        />
      );
    }
    if (s.type === 'portraits') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Portraits
            personnes={s.personnes}
            colonnes={s.colonnes}
            forme={s.forme}
          />
        </Section>
      );
    }
    if (s.type === 'timeline') {
      return (
        <Section id={id} titre={s.titre} fond={s.fond}>
          <Timeline etapes={s.etapes} alignement={s.alignement} />
        </Section>
      );
    }
    return null;
  })
}
