---
// Image centrée avec légende italique. Trois tailles prédéfinies.
import SmartImage from './SmartImage.astro';

type Props = {
  image: string;
  alt: string;
  legende?: string;
  credit?: string;
  taille?: 'petite' | 'moyenne' | 'grande';
};

const { image, alt, legende, credit, taille = 'moyenne' } = Astro.props;

const maxWidth = {
  petite: 'max-w-md',
  moyenne: 'max-w-2xl',
  grande: 'max-w-4xl',
}[taille];
---

<figure class:list={['mx-auto', maxWidth]}>
  <SmartImage src={image} alt={alt} class="w-full rounded-2xl" />
  {(legende || credit) && (
    <figcaption class="mt-3 text-center font-serif italic text-[15px] text-ink-3">
      {legende}
      {credit && (
        <span
          class="ml-3 font-mono text-[11px] not-italic uppercase text-ink-3"
          style="letter-spacing: 0.06em;"
        >
          © {credit}
        </span>
      )}
    </figcaption>
  )}
</figure>
