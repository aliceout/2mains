---
type Stat = {
  valeur: string;
  legende: string;
  source?: string;
};

type Props = { stats: Stat[] };
const { stats } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-3">
  {
    stats.map((s) => (
      <div class="rounded-xl border border-beige bg-paper p-6">
        <p class="text-4xl font-bold text-orange">{s.valeur}</p>
        <p class="mt-2 leading-snug">{s.legende}</p>
        {s.source && <p class="mt-3 text-xs opacity-70">{s.source}</p>}
      </div>
    ))
  }
</div>
