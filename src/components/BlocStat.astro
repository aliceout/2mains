---
// Grille de chiffres-clés. Inspiré de l'ImpenseSocial du proto :
// chiffre italique 60-64px orange, légende sans + source mono.
// La grille s'adapte au nombre de stats : 1, 2, 3 ou 4 colonnes.
type Stat = {
  valeur: string;
  legende: string;
  source?: string;
};

type Props = { stats: Stat[] };
const { stats } = Astro.props;

const colsClass = (() => {
  const n = stats.length;
  if (n <= 1) return 'md:grid-cols-1';
  if (n === 2) return 'md:grid-cols-2';
  if (n === 3) return 'md:grid-cols-3';
  // 4+ stats : 2 colonnes en tablette, 4 colonnes en desktop.
  return 'md:grid-cols-2 lg:grid-cols-4';
})();
---

<div class:list={['grid gap-8', colsClass]}>
  {
    stats.map((s) => (
      <div class="border-t border-line pt-6">
        <p class="font-serif italic font-medium text-[44px] leading-none tracking-tight text-orange md:text-[52px]">
          {s.valeur}
        </p>
        <p class="mt-4 max-w-[28ch] font-sans text-[15px] leading-snug text-ink-2">
          {s.legende}
        </p>
        {s.source && (
          <p
            class="mt-3 font-mono text-[11px] uppercase text-ink-3"
            style="letter-spacing: 0.04em;"
          >
            — {s.source}
          </p>
        )}
      </div>
    ))
  }
</div>
