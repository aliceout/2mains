---
// Encadré coloré pour faire ressortir un point clé. Inspiré des
// callouts éthiques de la page Structure du proto : border-left 3px,
// fond tinté, eyebrow mono uppercase coloré, body Inter Tight.
import { marked } from 'marked';

type Props = {
  ton?: 'info' | 'important' | 'astuce' | 'note';
  titre?: string;
  body: string; // markdown inline
};

const { ton = 'info', titre, body } = Astro.props;

// Mapping des tons sur les nouvelles teintes du design.
const styles = {
  info: {
    bg: 'bg-lav',
    border: 'border-violet',
    text: 'text-violet',
    label: 'Info',
  },
  important: {
    bg: 'bg-peach',
    border: 'border-orange',
    text: 'text-orange',
    label: 'Important',
  },
  astuce: {
    bg: 'bg-honey/60',
    border: 'border-honey',
    text: 'text-orange',
    label: 'À savoir',
  },
  note: {
    bg: 'bg-cream',
    border: 'border-ink-3',
    text: 'text-ink-3',
    label: 'Note',
  },
}[ton];

const html = marked.parse(body, { async: false }) as string;
---

<aside
  role="note"
  class:list={['rounded-md border-l-[3px] px-7 py-6', styles.bg, styles.border]}
>
  <p
    class:list={['mb-2 font-mono text-[11px] uppercase', styles.text]}
    style="letter-spacing: 0.12em;"
  >
    — {titre ?? styles.label}
  </p>
  <div
    class="callout-body font-sans text-[15.5px] leading-relaxed text-ink-2"
  >
    <Fragment set:html={html} />
  </div>
</aside>

<style>
  .callout-body :global(p) {
    margin-bottom: 0.5rem;
  }
  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout-body :global(strong) {
    font-weight: 500;
    color: var(--color-ink);
  }
  .callout-body :global(em) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    color: var(--color-orange);
  }
  .callout-body :global(a) {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
