---
// Logotype 2mains de femmes : deux arcs entrelacés (orange + violet)
// + wordmark serif italique. Tailles flexibles via les props.
type Props = {
  iconSize?: number;
  primaryFontSize?: number;
  secondaryFontSize?: number;
  primaryColor?: string;
  secondaryColor?: string;
};
const {
  iconSize = 32,
  primaryFontSize = 19,
  secondaryFontSize = 14,
  primaryColor = 'var(--color-orange)',
  secondaryColor = 'var(--color-violet)',
} = Astro.props;

const arcStrokePrimary = 'var(--color-orange-soft)';
const arcStrokeSecondary = 'var(--color-violet-soft)';
---

<span class="inline-flex items-center gap-2.5">
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M22 8 a8 8 0 1 0 0 16"
      stroke={arcStrokePrimary}
      stroke-width="2.5"
      fill="none"
      stroke-linecap="round"></path>
    <path
      d="M10 24 a8 8 0 1 0 0 -16"
      stroke={arcStrokeSecondary}
      stroke-width="2.5"
      fill="none"
      stroke-linecap="round"></path>
  </svg>
  <span class="flex flex-col font-serif" style="line-height: 1;">
    <span style={`font-size: ${primaryFontSize}px; color: ${primaryColor}; font-weight: 500;`}>
      2mains
    </span>
    <span
      style={`font-size: ${secondaryFontSize}px; color: ${secondaryColor}; font-style: italic; margin-top: 2px;`}
    >
      de femmes
    </span>
  </span>
</span>
