---
type Props = {
  titre: string;
  sousTitre?: string;
  accroche?: string;
  ctaPrimaire?: { label: string; href: string; externe?: boolean };
  ctaSecondaire?: { label: string; href: string; externe?: boolean };
  variant?: 'orange' | 'violet' | 'beige' | 'magenta' | 'vert' | 'bleu';
};

const {
  titre,
  sousTitre,
  accroche,
  ctaPrimaire,
  ctaSecondaire,
  variant = 'beige',
} = Astro.props;

const bg = {
  orange: 'bg-orange text-paper',
  violet: 'bg-violet text-paper',
  beige: 'bg-beige text-ink',
  magenta: 'bg-magenta text-paper',
  vert: 'bg-vert text-ink',
  bleu: 'bg-bleu text-paper',
}[variant];
---

<section class:list={['relative overflow-hidden', bg]}>
  <img
    src="/brand/filigrane.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -top-10 -right-10 h-80 w-80 opacity-20"
  />
  <div class="relative mx-auto max-w-6xl px-4 py-16 md:py-24">
    {sousTitre && <p class="mb-3 text-sm font-semibold tracking-wide uppercase opacity-80">{sousTitre}</p>}
    <h1 class="max-w-3xl text-4xl leading-tight font-bold md:text-5xl lg:text-6xl">{titre}</h1>
    {accroche && <p class="mt-5 max-w-2xl text-lg leading-relaxed opacity-95">{accroche}</p>}
    {(ctaPrimaire || ctaSecondaire) && (
      <div class="mt-8 flex flex-wrap gap-3">
        {ctaPrimaire && (
          <a
            href={ctaPrimaire.href}
            target={ctaPrimaire.externe ? '_blank' : undefined}
            rel={ctaPrimaire.externe ? 'noopener' : undefined}
            class="rounded-full bg-ink px-6 py-3 font-bold text-paper transition-colors hover:bg-magenta"
          >
            {ctaPrimaire.label}
          </a>
        )}
        {ctaSecondaire && (
          <a
            href={ctaSecondaire.href}
            target={ctaSecondaire.externe ? '_blank' : undefined}
            rel={ctaSecondaire.externe ? 'noopener' : undefined}
            class="rounded-full border-2 border-current px-6 py-3 font-bold transition-colors hover:bg-paper/10"
          >
            {ctaSecondaire.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
