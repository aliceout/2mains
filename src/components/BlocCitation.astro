---
// Citation simple en carte. Variant pilote la couleur de fond.
// Guillemet décoratif géant à gauche, citation en italique
// Newsreader, attribution en mono uppercase.
import { renderRichOrMarkdown } from '../lib/lexical';

type Props = {
  /** Citation markdown legacy. */
  citation?: string;
  /** Citation Lexical (nouveau richText). Si rempli, écrase citation. */
  citation_rich?: unknown;
  auteur: string;
  role?: string;
  variant?: 'beige' | 'violet' | 'paper';
};

const { citation, citation_rich, auteur, role, variant = 'beige' } = Astro.props;

// Rendu inline (sans <p>) : on est déjà dans un <blockquote>.
const citationHtml = renderRichOrMarkdown(citation_rich, citation, true);

const variantMap = {
  paper: { bg: 'bg-paper border border-line', text: 'text-ink', quote: 'text-orange' },
  beige: { bg: 'bg-cream', text: 'text-ink', quote: 'text-orange' },
  violet: { bg: 'bg-violet', text: 'text-paper', quote: 'text-honey' },
}[variant];
---

<figure
  class:list={[
    'relative overflow-hidden rounded-2xl px-8 pt-8 pb-7',
    variantMap.bg,
    variantMap.text,
  ]}
>
  <div
    class:list={[
      'pointer-events-none mb-2 font-serif italic font-medium leading-none',
      variantMap.quote,
    ]}
    style="font-size: 44px;"
    aria-hidden="true"
  >
    “
  </div>
  <blockquote
    class="font-serif italic font-normal text-[17px] leading-snug tracking-tight max-w-[44ch] md:text-[18px]"
  >
    {citationHtml ? <p set:html={citationHtml} /> : <slot />}
  </blockquote>
  <figcaption
    class="mt-5 font-mono text-[11px] uppercase opacity-90"
    style="letter-spacing: 0.06em;"
  >
    — {auteur}{role && <span class="opacity-80"> · {role}</span>}
  </figcaption>
</figure>
