---
// Image pleine largeur avec titre Newsreader en overlay. Position
// horizontale (gauche/centre/droite) × verticale (haut/milieu/bas).
// Scrim sombre par défaut pour assurer le contraste du texte clair.
import SmartImage from './SmartImage.astro';

type Props = {
  image: string;
  alt: string;
  titre: string;
  sousTitre?: string;
  hauteur?: 'petite' | 'moyenne' | 'grande';
  position_texte?: 'gauche' | 'centre' | 'droite';
  position_verticale?: 'haut' | 'milieu' | 'bas';
  scrim?: boolean;
};

const {
  image,
  alt,
  titre,
  sousTitre,
  hauteur = 'moyenne',
  position_texte = 'centre',
  position_verticale = 'milieu',
  scrim = true,
} = Astro.props;

const heightClass = {
  petite: 'h-72 md:h-90',
  moyenne: 'h-100 md:h-115',
  grande: 'h-128 md:h-160',
}[hauteur];

const flexH = {
  gauche: 'items-start text-left',
  centre: 'items-center text-center',
  droite: 'items-end text-right',
}[position_texte];

const flexV = {
  haut: 'justify-start pt-16',
  milieu: 'justify-center',
  bas: 'justify-end pb-16',
}[position_verticale];
---

<section class:list={['relative w-full overflow-hidden', heightClass]}>
  <SmartImage src={image} alt={alt} class="absolute inset-0 h-full w-full" eager />
  {scrim && (
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-linear-to-t from-ink/70 via-ink/30 to-transparent"
    />
  )}
  <div
    class:list={[
      'relative z-10 mx-auto flex h-full max-w-310 flex-col px-6 md:px-10',
      flexH,
      flexV,
    ]}
  >
    <div class="max-w-3xl text-paper drop-shadow-md">
      <h2 class="font-serif text-[40px] font-normal leading-[1.05] tracking-tight md:text-[64px]">
        {titre}
      </h2>
      {sousTitre && (
        <p class="mt-4 font-sans text-base leading-relaxed opacity-95 md:text-lg">
          {sousTitre}
        </p>
      )}
    </div>
  </div>
</section>
