---
// Étapes numérotées en colonnes (5 max idéalement) avec border-top
// colorée et numéro italique. Inspiré de Parcours dans final-home.jsx.
type Couleur = 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu';

type Etape = {
  titre: string;
  description?: string;
};

type Props = {
  etapes: Etape[];
  couleur?: Couleur;
};

const { etapes, couleur = 'orange' } = Astro.props;

const accentMap: Record<Couleur, { border: string; numero: string }> = {
  orange: { border: 'border-orange', numero: 'text-orange' },
  violet: { border: 'border-violet', numero: 'text-violet' },
  magenta: { border: 'border-rose', numero: 'text-rose' },
  vert: { border: 'border-moss', numero: 'text-moss' },
  bleu: { border: 'border-mauve', numero: 'text-mauve' },
};

const a = accentMap[couleur];

// Grid responsive : 1 col mobile → 2 col sm → autant que d'étapes
// (max 5) en desktop.
const colsClass = etapes.length >= 5
  ? 'sm:grid-cols-2 lg:grid-cols-5'
  : etapes.length === 4
    ? 'sm:grid-cols-2 lg:grid-cols-4'
    : etapes.length === 3
      ? 'sm:grid-cols-2 lg:grid-cols-3'
      : 'sm:grid-cols-2';
---

<ol class:list={['grid gap-6', colsClass]} aria-label="Étapes">
  {
    etapes.map((e, i) => (
      <li class:list={['border-t-2 pt-4', a.border]}>
        <div
          class:list={[
            'mb-3 font-serif italic font-medium text-[32px] leading-none tracking-tight',
            a.numero,
          ]}
        >
          0{i + 1}.
        </div>
        <h3 class="mb-2 font-serif text-[19px] font-medium leading-tight tracking-tight text-ink">
          {e.titre}
        </h3>
        {e.description && (
          <p class="font-sans text-[13.5px] leading-relaxed text-ink-2">
            {e.description}
          </p>
        )}
      </li>
    ))
  }
</ol>
