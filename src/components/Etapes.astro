---
/**
 * Étapes numérotées avec bulle colorée + trait de liaison.
 * Remplace les <ol> visuellement pauvres sur les pages "Comment on
 * travaille ensemble" / "Comment commencer" / "Un parcours type".
 */
type Etape = {
  titre: string;
  description?: string;
};

type Props = {
  etapes: Etape[];
  couleur?: 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu';
};

const { etapes, couleur = 'orange' } = Astro.props;

const bulletBg = {
  orange: 'bg-orange text-paper',
  violet: 'bg-violet text-paper',
  magenta: 'bg-magenta text-paper',
  vert: 'bg-vert text-ink',
  bleu: 'bg-bleu text-paper',
}[couleur];

const lineBg = {
  orange: 'bg-orange',
  violet: 'bg-violet',
  magenta: 'bg-magenta',
  vert: 'bg-vert',
  bleu: 'bg-bleu',
}[couleur];
---

<ol class="relative flex flex-col gap-6 md:flex-row md:gap-4" aria-label="Étapes">
  {
    etapes.map((e, i) => (
      <li class="relative flex items-start gap-4 md:flex-1 md:flex-col md:items-center md:text-center">
        <span
          class:list={[
            'relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-lg font-bold shadow-sm',
            bulletBg,
          ]}
          aria-hidden="true"
        >
          {i + 1}
        </span>
        {/* Trait de liaison horizontal (md+) */}
        {i < etapes.length - 1 && (
          <span
            class:list={[
              'absolute top-6 left-12 hidden h-0.5 -translate-y-1/2 opacity-40 md:block md:w-[calc(100%-3rem)]',
              lineBg,
            ]}
            aria-hidden="true"
          />
        )}
        <div class="flex-1 md:mt-4">
          <h3 class="mb-1 text-base font-bold">{e.titre}</h3>
          {e.description && (
            <p class="text-sm leading-relaxed opacity-90">{e.description}</p>
          )}
        </div>
      </li>
    ))
  }
</ol>
