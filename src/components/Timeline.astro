---
// Frise chronologique. Verticale (étapes empilées avec barre violette
// à gauche) ou alternée (zig-zag desktop). Date en mono uppercase
// orange, titre Newsreader 22px, body Inter Tight 14.
import SmartImage from './SmartImage.astro';
import { lexicalToHtml } from '../lib/lexical';

type Etape = {
  date: string;
  titre: string;
  /** Texte Lexical (richText). */
  texte_rich?: unknown;
  image?: string;
  image_alt?: string;
};

type Props = {
  etapes: Etape[];
  alignement?: 'vertical' | 'alterne';
};

const { etapes, alignement = 'vertical' } = Astro.props;
const alterne = alignement === 'alterne';
---

<ol
  class:list={[
    'relative mx-auto max-w-225',
    alterne ? '' : 'border-l-2 border-violet pl-8 md:pl-10',
  ]}
>
  {
    etapes.map((e, i) => {
      const right = alterne && i % 2 === 1;
      return (
        <li
          class:list={[
            'relative pb-12 last:pb-0',
            alterne ? 'md:grid md:grid-cols-2 md:gap-10' : '',
          ]}
        >
          <span
            aria-hidden="true"
            class:list={[
              'absolute h-3 w-3 rounded-full bg-violet ring-4 ring-paper',
              alterne
                ? 'left-1/2 top-1 -translate-x-1/2'
                : '-left-[calc(2rem+0.4rem)] top-2 md:-left-[calc(2.5rem+0.4rem)]',
            ]}
          />
          <div
            class:list={[
              alterne && right ? 'md:col-start-2 md:pl-10' : '',
              alterne && !right ? 'md:col-start-1 md:pr-10 md:text-right' : '',
            ]}
          >
            <p
              class="font-mono text-[11px] uppercase text-orange"
              style="letter-spacing: 0.08em;"
            >
              — {e.date}
            </p>
            <h3 class="mt-2 font-serif text-[22px] font-medium leading-tight tracking-tight text-ink">
              {e.titre}
            </h3>
            {e.texte_rich && (
              <div
                class="mt-2 font-sans text-sm leading-relaxed text-ink-2"
                set:html={lexicalToHtml(e.texte_rich)}
              />
            )}
            {e.image && (
              <SmartImage
                src={e.image}
                alt={e.image_alt ?? ''}
                class="mt-4 w-full max-w-sm rounded-xl"
              />
            )}
          </div>
        </li>
      );
    })
  }
</ol>
