---
// Cartes riches type "triptyque" : numéro 01/02/03 italique, titre,
// description, points-clés en liste, CTA optionnel. Inspiré du
// triptyque "Trois formats" dans la page Structure du proto.
import Blob from './atoms/Blob.astro';
import LinkArrow from './atoms/LinkArrow.astro';

type Couleur = 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu';

type Format = {
  titre: string;
  description?: string;
  points?: string[];
  couleur?: Couleur;
  cta?: {
    label: string;
    href: string;
    externe?: boolean;
  };
};

type Props = {
  formats: Format[];
  colonnes?: 2 | 3;
};

const { formats, colonnes = 2 } = Astro.props;

const gridClass = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-2 lg:grid-cols-3',
}[colonnes];

type FormatConfig = {
  accent: 'orange' | 'violet' | 'rose' | 'moss' | 'mauve';
  bgClass: string;
  blob: 'orange' | 'violet' | 'rose' | 'moss' | 'mauve' | 'honey' | 'peach';
};

const couleurMap: Record<Couleur, FormatConfig> = {
  orange: { accent: 'orange', bgClass: 'bg-peach', blob: 'rose' },
  violet: { accent: 'violet', bgClass: 'bg-lav', blob: 'mauve' },
  magenta: { accent: 'rose', bgClass: 'bg-rose/40', blob: 'orange' },
  vert: { accent: 'moss', bgClass: 'bg-honey/50', blob: 'moss' },
  bleu: { accent: 'mauve', bgClass: 'bg-lav', blob: 'mauve' },
};

const accentText: Record<string, string> = {
  orange: 'text-orange',
  violet: 'text-violet',
  rose: 'text-rose',
  moss: 'text-moss',
  mauve: 'text-mauve',
};

const accentBg: Record<string, string> = {
  orange: 'bg-orange',
  violet: 'bg-violet',
  rose: 'bg-rose',
  moss: 'bg-moss',
  mauve: 'bg-mauve',
};

const accentBorder: Record<string, string> = {
  orange: 'border-orange/20',
  violet: 'border-violet/20',
  rose: 'border-rose/30',
  moss: 'border-moss/25',
  mauve: 'border-mauve/30',
};
---

<div class:list={['grid gap-6', gridClass]}>
  {
    formats.map((f, i) => {
      const config = couleurMap[f.couleur ?? 'orange'];
      const numero = String(i + 1).padStart(2, '0');
      return (
        <article
          class:list={[
            'relative flex min-h-95 flex-col overflow-hidden rounded-2xl p-8',
            config.bgClass,
          ]}
        >
          <Blob
            size={140}
            color={config.blob}
            seed={i + 2}
            opacity={0.25}
            class="pointer-events-none absolute -bottom-10 -right-10"
          />
          <div class="relative mb-5 flex items-baseline gap-3">
            <span
              class:list={[
                'font-serif italic font-medium text-[56px] leading-none tracking-tight',
                accentText[config.accent],
              ]}
            >
              {numero}
            </span>
            <span
              class:list={['h-px flex-1 opacity-30', accentBg[config.accent]]}
              aria-hidden="true"
            />
          </div>
          <h3 class="relative mb-3 font-serif text-[26px] font-medium leading-tight tracking-tight text-ink">
            {f.titre}
          </h3>
          {f.description && (
            <p class="relative mb-5 font-sans text-sm leading-relaxed text-ink-2">
              {f.description}
            </p>
          )}
          {f.points && f.points.length > 0 && (
            <ul class="relative mb-6 flex-1 space-y-2 font-sans text-sm text-ink-2">
              {f.points.map((p) => (
                <li class="flex items-start gap-2.5">
                  <span
                    class:list={[
                      'mt-2 inline-block h-1 w-1 shrink-0 rounded-full',
                      accentBg[config.accent],
                    ]}
                    aria-hidden="true"
                  />
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          )}
          {f.cta && (
            <div
              class:list={[
                'relative mt-auto border-t pt-4',
                accentBorder[config.accent],
              ]}
            >
              <LinkArrow
                href={f.cta.href}
                color={config.accent}
                external={f.cta.externe}
              >
                {f.cta.label}
              </LinkArrow>
            </div>
          )}
        </article>
      );
    })
  }
</div>
