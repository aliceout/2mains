---
// FAQ — accordéon basé sur <details>/<summary> HTML natif.
// Accessible clavier, pas de JS requis.
//
// Design refondu : pas de fond carte, juste des lignes fines entre
// questions. Titre Newsreader 22px medium, plus orange à droite.
import { renderRichOrMarkdown } from '../lib/lexical';

type Question = {
  question: string;
  /** Réponse markdown legacy. */
  reponse?: string;
  /** Réponse Lexical (nouveau richText). Si remplie, écrase reponse. */
  reponse_rich?: unknown;
};

type Props = {
  questions: Question[];
};

const { questions } = Astro.props;

const rendered = questions.map((q) => ({
  question: q.question,
  html: renderRichOrMarkdown(q.reponse_rich, q.reponse),
}));
---

<div class="mx-auto max-w-215">
  {
    rendered.map((q, i) => (
      <details
        class:list={[
          'group border-t border-line',
          i === rendered.length - 1 ? 'border-b' : '',
        ]}
      >
        <summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-4 font-serif text-[18px] font-medium tracking-tight text-ink hover:text-orange focus-visible:outline-2 focus-visible:outline-violet md:text-[19px]">
          <span>{q.question}</span>
          <span
            class="text-ink-3 transition-all group-open:text-orange group-open:rotate-45"
            aria-hidden="true"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              focusable="false"
            >
              <path
                d="M7 1v12M1 7h12"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
            </svg>
          </span>
        </summary>
        <div class="faq-body pb-6 font-sans text-[16px] leading-relaxed text-ink-2 max-w-[65ch]">
          <Fragment set:html={q.html} />
        </div>
      </details>
    ))
  }
</div>

<style>
  details summary::-webkit-details-marker { display: none; }
  details summary::marker { content: ''; }
  .faq-body :global(p) {
    margin-bottom: 0.75rem;
  }
  .faq-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .faq-body :global(ul),
  .faq-body :global(ol) {
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
  }
  .faq-body :global(ul) {
    list-style: disc;
  }
  .faq-body :global(ol) {
    list-style: decimal;
  }
  .faq-body :global(a) {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .faq-body :global(strong) {
    font-weight: 500;
    color: var(--color-ink);
  }
  .faq-body :global(em) {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-orange);
  }
</style>
