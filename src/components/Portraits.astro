---
// Grille de personnes avec photo ronde/carrée, nom, rôle, bio. Le
// proto ne montre pas explicitement de portraits — on s'inspire de
// la structure des cards (mêmes radius, même typo) mais centré.
import SmartImage from './SmartImage.astro';
import LinkArrow from './atoms/LinkArrow.astro';

type Personne = {
  nom: string;
  role?: string;
  photo?: string;
  photo_alt?: string;
  bio?: string;
  lien?: string;
  lien_label?: string;
};

type Props = {
  personnes: Personne[];
  colonnes?: 2 | 3 | 4;
  forme?: 'rond' | 'carre';
};

const { personnes, colonnes = 3, forme = 'rond' } = Astro.props;

const colClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 md:grid-cols-3',
  4: 'sm:grid-cols-2 md:grid-cols-4',
}[colonnes];

const photoClass =
  forme === 'rond'
    ? 'rounded-full aspect-square'
    : 'rounded-2xl aspect-[4/5]';
---

<ul class:list={['grid gap-10', colClass]}>
  {
    personnes.map((p) => (
      <li class="flex flex-col items-center text-center">
        {p.photo ? (
          <SmartImage
            src={p.photo}
            alt={p.photo_alt ?? `Portrait de ${p.nom}`}
            class:list={['w-40 md:w-44', photoClass]}
          />
        ) : (
          <div
            aria-hidden="true"
            class:list={[
              'flex w-40 md:w-44 items-center justify-center bg-cream font-serif italic text-3xl font-medium text-violet/50',
              photoClass,
            ]}
          >
            {p.nom
              .split(' ')
              .map((w) => w[0])
              .join('')
              .slice(0, 2)
              .toUpperCase()}
          </div>
        )}
        <p class="mt-4 font-serif text-lg font-medium tracking-tight text-ink">
          {p.nom}
        </p>
        {p.role && (
          <p class="mt-1 font-mono text-[11px] uppercase text-violet" style="letter-spacing: 0.06em;">
            {p.role}
          </p>
        )}
        {p.bio && (
          <p class="mt-3 max-w-xs font-sans text-sm leading-relaxed text-ink-2">
            {p.bio}
          </p>
        )}
        {p.lien && (
          <p class="mt-3">
            <LinkArrow href={p.lien} color="orange" external>
              {p.lien_label ?? 'En savoir plus'}
            </LinkArrow>
          </p>
        )}
      </li>
    ))
  }
</ul>
