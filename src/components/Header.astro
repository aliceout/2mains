---
// Header sticky inspiré du design handoff (NavBar dans final-home.jsx).
// Logo SVG (brand/logo.svg) à gauche, navigation au centre (avec
// dropdowns hover/focus pour les parents non cliquables), bouton
// primaire « Faire un don » à droite.
//
// On garde l'arborescence complète (15+ pages, navigation existante avec
// dropdowns) — c'est uniquement la couche visuelle qui bascule sur le
// nouveau design : couleurs chaudes, fonts éditoriales, lien actif
// souligné de 1.5px orange.
import { navigation, matchesItem, type SiteSettings } from '../lib/site';
import Btn from './atoms/Btn.astro';
import Arrow from './atoms/Arrow.astro';

type Props = { settings: SiteSettings };
const { settings } = Astro.props;

const path = Astro.url.pathname;
const isChildActive = (href: string | undefined): boolean => {
  if (!href) return false;
  const clean = path.replace(/\/$/, '') || '/';
  return clean === href || clean.startsWith(href + '/');
};
---

<header
  class="sticky top-0 z-40 border-b border-line bg-paper-white/95 backdrop-blur"
>
  <div class="flex items-center">
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 py-5 pl-6 md:pl-10"
      aria-label={`Accueil — ${settings.nom_asso}`}
    >
      <img src="/brand/logo.svg" alt="" class="h-10 w-auto" width="140" height="40" />
      <span class="sr-only">{settings.nom_asso}</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden py-5 pl-10 lg:block">
      <ul class="flex items-center gap-7 font-sans text-sm">
        {
          navigation.map((item) => {
            const active = matchesItem(path, item);
            const triggerClass = [
              'inline-block py-1 transition-colors hover:text-orange',
              active
                ? 'text-orange border-b-[1.5px] border-orange pb-0.5'
                : 'text-ink border-b-[1.5px] border-transparent pb-0.5',
            ];
            return (
              <li class="relative group">
                {item.href ? (
                  <a
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                    class:list={triggerClass}
                  >
                    {item.label}
                  </a>
                ) : (
                  <button
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    class:list={[...triggerClass, 'cursor-default bg-transparent']}
                  >
                    {item.label}
                  </button>
                )}
                {item.children && (
                  <ul class="invisible absolute top-full left-0 mt-2 min-w-56 rounded-md border border-line bg-paper-white p-2 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block rounded px-3 py-2 text-sm transition-colors hover:bg-paper-cream',
                            isChildActive(child.href)
                              ? 'text-orange'
                              : 'text-ink',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>

    <!-- Spacer pour pousser les boutons (et le hamburger mobile) à l'extrême droite. -->
    <div class="flex-1"></div>

    <!-- Hamburger : visible mobile + tablette (md), planqué dès lg (la nav inline prend le relais). -->
    <button
      type="button"
      class="mx-4 inline-flex h-10 w-10 items-center justify-center rounded-md border border-line text-ink lg:hidden"
      aria-controls="menu-mobile"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
      data-menu-toggle
    >
      <svg
        viewBox="0 0 24 24"
        width="22"
        height="22"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>

    <!-- 3 boutons d'action — pleine hauteur, flush bord droit de l'écran. -->
    <div class="hidden self-stretch md:flex md:items-stretch">
      <a
        href="/actualites"
        class="flex w-24 flex-col items-center justify-center gap-1 bg-lav text-ink transition-opacity hover:opacity-85 lg:w-28"
        aria-label="Blog — actualités de l'association"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="8" y1="13" x2="16" y2="13" />
          <line x1="8" y1="17" x2="13" y2="17" />
        </svg>
        <span class="font-sans text-xs font-bold uppercase tracking-wider">Blog</span>
      </a>
      <a
        href="/agir"
        class="flex w-24 flex-col items-center justify-center gap-1 bg-honey text-ink transition-opacity hover:opacity-85 lg:w-28"
        aria-label="Agir — s'engager auprès de l'association"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>
        <span class="font-sans text-xs font-bold uppercase tracking-wider">Agir</span>
      </a>
      <a
        href="/soutenir"
        class="flex w-24 flex-col items-center justify-center gap-1 bg-orange text-paper transition-opacity hover:opacity-85 lg:w-28"
        aria-label="Soutenir — don, mécénat"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="16" />
          <line x1="8" y1="12" x2="16" y2="12" />
        </svg>
        <span class="font-sans text-xs font-bold uppercase tracking-wider">Soutenir</span>
      </a>
    </div>
  </div>

  <div
    id="menu-mobile"
    class="hidden border-t border-line bg-paper-white lg:hidden"
    data-menu
  >
    <nav aria-label="Navigation mobile" class="mx-auto max-w-310 px-6 py-4">
      <ul class="space-y-1 font-sans">
        {
          navigation.map((item) => {
            const active = matchesItem(path, item);
            return (
              <li>
                {item.href ? (
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded px-3 py-2 text-base',
                      active
                        ? 'bg-paper-cream text-orange'
                        : 'text-ink hover:bg-paper-cream',
                    ]}
                    aria-current={active ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                ) : (
                  <p
                    class:list={[
                      'block px-3 py-2 text-base',
                      active ? 'text-orange' : 'text-ink',
                    ]}
                  >
                    {item.label}
                  </p>
                )}
                {item.children && (
                  <ul class="ml-3 mt-1 space-y-1 border-l border-line pl-3">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block rounded px-3 py-2 text-sm',
                            isChildActive(child.href)
                              ? 'text-orange'
                              : 'text-ink-2 hover:bg-paper-cream',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })
        }
        <li class="pt-3 flex flex-col gap-2">
          <Btn href="/actualites" variant="violet">Blog</Btn>
          <Btn href="/agir" variant="ghost">Agir</Btn>
          <Btn href="/soutenir" variant="primary">
            Soutenir <Arrow color="white" />
          </Btn>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute(
        'aria-label',
        open ? 'Ouvrir le menu' : 'Fermer le menu',
      );
    });
  }
</script>
