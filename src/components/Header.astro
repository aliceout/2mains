---
// Header sticky inspiré du design handoff (NavBar dans final-home.jsx).
// Logo SVG (brand/logo.svg) à gauche, navigation au centre (avec
// dropdowns hover/focus pour les parents non cliquables), 3 boutons
// colorés à droite.
//
// Nav et boutons sont éditables depuis /cms/admin (global Navigation).
// Les visuels des 3 boutons (icône SVG + couleur de fond + variante
// mobile) sont figés par position — Audrey peut modifier libellé et
// destination, mais l'identité graphique reste cohérente.
import { matchesItem, type SiteSettings } from '../lib/site';
import Btn from './atoms/Btn.astro';
import Arrow from './atoms/Arrow.astro';

type Props = { settings: SiteSettings };
const { settings } = Astro.props;

const path = Astro.url.pathname;
const isChildActive = (href: string | undefined): boolean => {
  if (!href) return false;
  const clean = path.replace(/\/$/, '') || '/';
  return clean === href || clean.startsWith(href + '/');
};

// Visuels figés des 3 boutons d'action (par position dans header_buttons).
// L'icône SVG embarque le label visible ("LE BLOG" / "NOUS REJOINDRE" /
// "NOUS SOUTENIR") — d'où la cohérence position/visuel à maintenir côté
// admin. Sur mobile, on retombe sur le composant Btn avec sa variante
// charte.
const HEADER_BUTTON_VISUALS = [
  { svg: '/brand/blog.svg', bg: 'bg-violet', mobileVariant: 'violet' as const },
  { svg: '/brand/rejoindre.svg', bg: 'bg-magenta', mobileVariant: 'ghost' as const },
  { svg: '/brand/soutenir.svg', bg: 'bg-orange', mobileVariant: 'primary' as const },
];
const buttons = settings.header_buttons.slice(0, 3);
---

<header
  class="sticky top-0 z-40 border-b border-line bg-paper-white/95 backdrop-blur"
>
  <div class="flex items-center">
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 py-4 pl-6 md:pl-10"
      aria-label={`Accueil — ${settings.nom_asso}`}
    >
      <img src="/brand/logo.svg" alt="" class="h-10 w-auto" width="140" height="40" />
      <span class="sr-only">{settings.nom_asso}</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden py-4 pl-10 lg:block">
      <ul class="flex items-center gap-7 font-sans text-sm">
        {
          settings.header_nav.map((item) => {
            const active = matchesItem(path, item);
            const triggerClass = [
              'inline-block py-1 transition-colors hover:text-orange',
              active
                ? 'text-orange border-b-[1.5px] border-orange pb-0.5'
                : 'text-ink border-b-[1.5px] border-transparent pb-0.5',
            ];
            return (
              <li class="relative group">
                {item.href ? (
                  <a
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                    class:list={triggerClass}
                  >
                    {item.label}
                  </a>
                ) : (
                  <button
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    class:list={[...triggerClass, 'cursor-default bg-transparent']}
                  >
                    {item.label}
                  </button>
                )}
                {item.children && (
                  <ul class="invisible absolute top-full left-0 mt-2 min-w-56 rounded-md border border-line bg-paper-white p-2 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block rounded px-3 py-2 text-sm transition-colors hover:bg-paper-cream',
                            isChildActive(child.href)
                              ? 'text-orange'
                              : 'text-ink',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>

    <!-- Spacer pour pousser les boutons (et le hamburger mobile) à l'extrême droite. -->
    <div class="flex-1"></div>

    <!-- Hamburger : visible mobile + tablette (md), planqué dès lg (la nav inline prend le relais). -->
    <button
      type="button"
      class="mx-4 inline-flex h-10 w-10 items-center justify-center rounded-md border border-line text-ink lg:hidden"
      aria-controls="menu-mobile"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
      data-menu-toggle
    >
      <svg
        viewBox="0 0 24 24"
        width="22"
        height="22"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>

    <!-- 3 boutons d'action — pleine hauteur, flush bord droit de l'écran.
         Couleurs sur les tokens charte (bg-violet / bg-magenta / bg-orange).
         Icônes : SVG fournis par Audrey (bulle de blog, personnage bras
         levés, main + 3 points) — chargés via mask-image pour que la
         couleur d'encrage suive `text-paper` du parent (les fichiers
         eux-mêmes sont figés en dark teal #2f4d53). Le label « LE BLOG /
         NOUS REJOINDRE / NOUS SOUTENIR » est intégré dans chaque SVG. -->
    <div class="hidden self-stretch md:flex md:items-stretch">
      {
        buttons.map((btn, i) => {
          const visual = HEADER_BUTTON_VISUALS[i];
          if (!visual) return null;
          return (
            <a
              href={btn.href}
              class:list={[
                'flex w-24 items-center justify-center text-paper transition-opacity hover:opacity-85 lg:w-28',
                visual.bg,
              ]}
              aria-label={btn.label}
            >
              <span
                class="block h-[52px] w-[52px] bg-current lg:h-[54px] lg:w-[54px]"
                style={`-webkit-mask:url('${visual.svg}') center/contain no-repeat;mask:url('${visual.svg}') center/contain no-repeat;`}
                aria-hidden="true"
              />
            </a>
          );
        })
      }
    </div>
  </div>

  <div
    id="menu-mobile"
    class="hidden border-t border-line bg-paper-white lg:hidden"
    data-menu
  >
    <nav aria-label="Navigation mobile" class="mx-auto max-w-310 px-6 py-4">
      <ul class="space-y-1 font-sans">
        {
          settings.header_nav.map((item) => {
            const active = matchesItem(path, item);
            return (
              <li>
                {item.href ? (
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded px-3 py-2 text-base',
                      active
                        ? 'bg-paper-cream text-orange'
                        : 'text-ink hover:bg-paper-cream',
                    ]}
                    aria-current={active ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                ) : (
                  <p
                    class:list={[
                      'block px-3 py-2 text-base',
                      active ? 'text-orange' : 'text-ink',
                    ]}
                  >
                    {item.label}
                  </p>
                )}
                {item.children && (
                  <ul class="ml-3 mt-1 space-y-1 border-l border-line pl-3">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block rounded px-3 py-2 text-sm',
                            isChildActive(child.href)
                              ? 'text-orange'
                              : 'text-ink-2 hover:bg-paper-cream',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })
        }
        <li class="pt-3 flex flex-col gap-2">
          {
            buttons.map((btn, i) => {
              const visual = HEADER_BUTTON_VISUALS[i];
              if (!visual) return null;
              const isLast = i === buttons.length - 1;
              return (
                <Btn href={btn.href} variant={visual.mobileVariant}>
                  {btn.label}
                  {isLast && <Arrow color="white" />}
                </Btn>
              );
            })
          }
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute(
        'aria-label',
        open ? 'Ouvrir le menu' : 'Fermer le menu',
      );
    });
  }
</script>
