---
import type { SiteSettings } from '../lib/site';

type Props = { settings: SiteSettings };
const { settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-16 bg-beige">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-3">
    <div>
      <img
        src="/brand/logo.svg"
        alt={settings.nom_asso}
        class="h-12 w-auto"
        width="160"
        height="48"
      />
      <p class="mt-3 max-w-md text-sm leading-relaxed">{settings.mission}</p>

      <h2 class="mt-6 mb-3 font-bold">Contact</h2>
      <ul class="space-y-1 text-sm">
        <li>
          <a href={`mailto:${settings.email_contact}`} class="hover:text-orange">
            {settings.email_contact}
          </a>
        </li>
        <li>{settings.telephone}</li>
        <li>{settings.adresse}</li>
      </ul>
    </div>

    <div>
      <h2 class="mb-3 font-bold">Agir &amp; soutenir</h2>
      <ul class="space-y-1 text-sm">
        <li><a href="/agir" class="hover:text-orange">Agir avec nous</a></li>
        <li>
          <a
            href={settings.helloasso_don}
            target="_blank"
            rel="noopener"
            class="hover:text-orange"
          >
            Faire un don (HelloAsso)
          </a>
        </li>
        <li>
          <a href="/soutenir/mecenat" class="hover:text-orange">Mécénat entreprises</a>
        </li>
        <li><a href="/contact" class="hover:text-orange">Nous contacter</a></li>
      </ul>

      <h2 class="mt-6 mb-3 font-bold">Suivre</h2>
      <ul class="space-y-1 text-sm">
        <li><a href="/actualites" class="hover:text-orange">Actualités</a></li>
        <li><a href="/agenda" class="hover:text-orange">Agenda</a></li>
        <li>
          <a href="/actualites.rss.xml" class="hover:text-orange">📡 Flux RSS</a>
        </li>
      </ul>
    </div>

    <div>
      <h2 class="mb-3 font-bold">Infos légales</h2>
      <ul class="space-y-1 text-sm">
        <li>
          <a href="/mentions-legales" class="hover:text-orange">Mentions légales</a>
        </li>
        <li>
          <a href="/politique-confidentialite" class="hover:text-orange">
            Politique de confidentialité
          </a>
        </li>
        <li>
          <a href="/accessibilite" class="hover:text-orange">
            Accessibilité : non conforme
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-paper/60">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start gap-2 px-4 py-4 text-xs md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} {settings.nom_asso} — tous droits réservés.</p>
      <p>Dons et adhésions sécurisés via HelloAsso.</p>
    </div>
  </div>
</footer>
