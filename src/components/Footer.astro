---
// Footer fond sombre #2B2419 inspiré du design handoff. Wordmark
// teinté + mission + colonnes de liens. Pas de barre basse de
// copyright (retirée par décision utilisateur précédente). Pas de
// contact email/tel rendu (anti-spam).
//
// Les colonnes de liens sont éditables depuis /cms/admin (global
// Navigation > footer_columns). Le nombre de colonnes (1 à 4) ajuste
// dynamiquement la grille — le bloc logo+mission garde toujours
// md:col-span-2 à gauche.
//
// Couleurs propres au footer (codées en dur car spécifiques à cette
// surface foncée, pas réutilisées ailleurs) :
//   bg :    #2B2419 (encre profonde, plus chaude que ink)
//   text :  #D8CFBF (paper-cream-ish, contraste AA sur le fond)
//   meta :  #9C9080 (méta-infos plus sourdes)
import type { SiteSettings } from '../lib/site';
import { lexicalToHtmlInline } from '../lib/lexical';

type Props = { settings: SiteSettings };
const { settings } = Astro.props;

// Mission en HTML inline (gras/italique/liens).
const missionHtml = lexicalToHtmlInline(settings.mission_rich);

// SHA du commit déployé, injecté en build-arg par le CI (cf
// Dockerfile.site + .github/workflows/docker-build.yml). En dev local
// process.env.GIT_SHA est undefined → on affiche "dev".
const gitSha = process.env.GIT_SHA ?? '';
const shortSha = gitSha ? gitSha.slice(0, 7) : 'dev';
const commitUrl = gitSha
  ? `https://github.com/aliceout/2mains/commit/${gitSha}`
  : null;

// Grille dynamique : logo+mission prend md:col-span-2, puis 1 colonne
// par item de footer_columns. Tailwind purge les classes non littérales,
// donc on énumère explicitement les 4 cas.
const colCount = Math.min(settings.footer_columns.length, 4);
const gridClass =
  colCount === 1
    ? 'md:grid-cols-3'
    : colCount === 2
      ? 'md:grid-cols-4'
      : colCount === 3
        ? 'md:grid-cols-5'
        : 'md:grid-cols-6';
---

<footer class="mt-16 bg-[#2B2419]">
  <div
    class:list={[
      'mx-auto grid max-w-310 gap-12 px-6 py-20 md:gap-16 md:px-10',
      gridClass,
    ]}
  >
    <div class="md:col-span-2">
      <img
        src="/brand/logo.svg"
        alt={settings.nom_asso}
        class="h-12 w-auto"
        width="181"
        height="48"
      />
      <p
        class="mt-5 max-w-[32ch] font-sans text-sm leading-relaxed text-[#9C9080]"
        set:html={missionHtml}
      />
    </div>

    {
      settings.footer_columns.slice(0, 4).map((col) => (
        <div>
          <h2
            class="mb-5 font-mono text-[11px] font-medium uppercase text-paper-white"
            style="letter-spacing: 0.1em;"
          >
            {col.title}
          </h2>
          <ul class="grid gap-2.5 font-sans text-sm">
            {col.links.map((link) => {
              const isExternal = /^https?:\/\//.test(link.href);
              return (
                <li>
                  <a
                    href={link.href}
                    target={isExternal ? '_blank' : undefined}
                    rel={isExternal ? 'noopener' : undefined}
                    class:list={[
                      'transition-colors',
                      link.highlight
                        ? 'text-orange-soft hover:text-orange'
                        : 'text-[#9C9080] hover:text-orange-soft',
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="border-t border-[#3a3327] px-6 py-4 text-center font-mono text-xs text-[#6e6557] md:px-10">
    version{' '}
    {
      commitUrl ? (
        <a
          href={commitUrl}
          target="_blank"
          rel="noopener nofollow"
          class="hover:text-orange-soft"
        >
          {shortSha}
        </a>
      ) : (
        <span>{shortSha}</span>
      )
    }
  </div>
</footer>
