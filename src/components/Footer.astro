---
// Footer fond sombre #2B2419 inspiré du design handoff. Wordmark
// teinté + mission + 2 colonnes de liens. Pas de barre basse de
// copyright (retirée par décision utilisateur précédente). Pas de
// contact email/tel rendu (anti-spam).
//
// Couleurs propres au footer (codées en dur car spécifiques à cette
// surface foncée, pas réutilisées ailleurs) :
//   bg :    #2B2419 (encre profonde, plus chaude que ink)
//   text :  #D8CFBF (paper-cream-ish, contraste AA sur le fond)
//   meta :  #9C9080 (méta-infos plus sourdes)
import type { SiteSettings } from '../lib/site';

type Props = { settings: SiteSettings };
const { settings } = Astro.props;
---

<footer class="mt-16 bg-[#2B2419]">
  <div
    class="mx-auto grid max-w-310 gap-12 px-6 py-20 md:grid-cols-4 md:gap-16 md:px-10"
  >
    <div class="md:col-span-2">
      <div class="flex items-center gap-2.5">
        <svg
          width="36"
          height="36"
          viewBox="0 0 32 32"
          fill="none"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M22 8 a8 8 0 1 0 0 16"
            stroke="var(--color-orange-soft)"
            stroke-width="2.5"
            fill="none"
            stroke-linecap="round"></path>
          <path
            d="M10 24 a8 8 0 1 0 0 -16"
            stroke="var(--color-violet-soft)"
            stroke-width="2.5"
            fill="none"
            stroke-linecap="round"></path>
        </svg>
        <span class="flex flex-col font-serif" style="line-height: 1;">
          <span
            style="font-size: 22px; color: var(--color-orange-soft); font-weight: 500;"
          >
            2mains
          </span>
          <span
            style="font-size: 16px; color: #A39DBF; font-style: italic; margin-top: 2px;"
          >
            de femmes
          </span>
        </span>
      </div>
      <p
        class="mt-5 max-w-[32ch] font-sans text-sm leading-relaxed text-[#9C9080]"
      >
        {settings.mission}
      </p>
    </div>

    <div>
      <h2
        class="mb-5 font-mono text-[11px] font-medium uppercase text-paper-white"
        style="letter-spacing: 0.1em;"
      >
        Actualités
      </h2>
      <ul class="grid gap-2.5 font-sans text-sm">
        <li>
          <a
            href="/actualites"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Blog
          </a>
        </li>
        <li>
          <a
            href="/agenda"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Agenda
          </a>
        </li>
        <li>
          <a
            href="/documents"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Nos documents cadres
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Nous contacter
          </a>
        </li>
        <li>
          <a
            href={settings.helloasso_don}
            target="_blank"
            rel="noopener"
            class="text-orange-soft transition-colors hover:text-orange"
          >
            Faire un don →
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h2
        class="mb-5 font-mono text-[11px] font-medium uppercase text-paper-white"
        style="letter-spacing: 0.1em;"
      >
        Infos légales
      </h2>
      <ul class="grid gap-2.5 font-sans text-sm">
        <li>
          <a
            href="/mentions-legales"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Mentions légales
          </a>
        </li>
        <li>
          <a
            href="/rgpd"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            RGPD et confidentialité
          </a>
        </li>
        <li>
          <a
            href="/accessibilite"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Accessibilité : non conforme
          </a>
        </li>
        <li>
          <a
            href={settings.helloasso_newsletter ?? settings.helloasso_don}
            target="_blank"
            rel="noopener"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            S'inscrire à la newsletter →
          </a>
        </li>
        <li>
          <a
            href="/cms/admin"
            rel="nofollow"
            class="text-[#9C9080] transition-colors hover:text-orange-soft"
          >
            Admin
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
