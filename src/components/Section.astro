---
// Section refondue sur le design handoff. Espacements 120/80/64
// (large/medium/compact), titre en Newsreader 56-72px avec
// italique d'emphase optionnel (`*mot*`) coloré + souligné
// manuscrit. Blob décoratif optionnel en background.
//
// Les noms de fond historiques (paper, beige, violet, orange,
// magenta, vert, bleu) sont conservés pour compat CMS, mais
// remappés sur la nouvelle palette. Sur fond sombre (violet,
// orange) le texte bascule en paper.
import HandUnderline from './atoms/HandUnderline.astro';
import Blob from './atoms/Blob.astro';

type Fond = 'paper' | 'beige' | 'violet' | 'orange' | 'magenta' | 'vert' | 'bleu';
type Taille = 'sm' | 'md' | 'lg';

type Props = {
  titre?: string;
  fond?: Fond;
  taille?: Taille;
  id?: string;
  /** Affiche un blob décoratif en arrière-plan (couleur dérivée du fond). */
  blob?: boolean;
  /** Couleur d'accent pour les italiques d'emphase dans le titre.
   *  Default : déduit du fond (orange sur fond clair, honey sur violet). */
  accent?: 'orange' | 'violet' | 'rose' | 'mauve' | 'moss' | 'honey';
};

const {
  titre,
  fond = 'paper',
  taille = 'md',
  id,
  blob = false,
  accent: accentProp,
} = Astro.props;

// Mapping fond → bg + text + (optionnel) couleur de blob déco.
type FondConfig = {
  bg: string;
  text: string;
  blob: 'orange' | 'violet' | 'rose' | 'mauve' | 'moss' | 'honey' | 'peach' | 'lav' | 'cream';
};

const fondMap: Record<Fond, FondConfig> = {
  paper: { bg: 'bg-paper', text: 'text-ink', blob: 'peach' },
  beige: { bg: 'bg-cream', text: 'text-ink', blob: 'rose' },
  violet: { bg: 'bg-violet', text: 'text-paper', blob: 'mauve' },
  orange: { bg: 'bg-orange', text: 'text-paper', blob: 'rose' },
  magenta: { bg: 'bg-rose', text: 'text-ink', blob: 'orange' },
  vert: { bg: 'bg-moss', text: 'text-paper', blob: 'honey' },
  bleu: { bg: 'bg-mauve', text: 'text-ink', blob: 'lav' },
};

const f = fondMap[fond];

// Padding vertical par section (top + bottom). Deux sections
// adjacentes cumulent leurs paddings, donc on reste mesuré pour
// éviter les vides à 240px entre deux blocs.
const padClass = {
  sm: 'py-6 md:py-8',
  md: 'py-8 md:py-14',
  lg: 'py-12 md:py-20',
}[taille];

// Couleur d'accent par défaut, choisie pour garantir le contraste
// avec le fond. Sur fonds sombres (violet, orange, vert/moss) on
// part sur honey ; sur fond rose on part sur violet pour casser
// la teinte chaude ; sinon orange.
type DefaultAccent = 'orange' | 'violet' | 'honey';
const defaultAccentByFond: Record<Fond, DefaultAccent> = {
  paper: 'orange',
  beige: 'orange',
  violet: 'honey',
  orange: 'honey',
  magenta: 'violet',
  vert: 'honey',
  bleu: 'violet',
};
const accent = accentProp ?? defaultAccentByFond[fond];

const accentColorClass: Record<string, string> = {
  orange: 'text-orange',
  violet: 'text-violet',
  rose: 'text-rose',
  mauve: 'text-mauve',
  moss: 'text-moss',
  honey: 'text-honey',
};

// Parser titre pour `*italique*`.
type TitleToken =
  | { type: 'text'; text: string }
  | { type: 'em'; text: string };

function parseTitle(s: string): TitleToken[] {
  const tokens: TitleToken[] = [];
  const parts = s.split(/(\*[^*]+\*)/);
  for (const part of parts) {
    if (!part) continue;
    if (part.startsWith('*') && part.endsWith('*') && part.length > 2) {
      tokens.push({ type: 'em', text: part.slice(1, -1) });
    } else {
      tokens.push({ type: 'text', text: part });
    }
  }
  return tokens;
}

const titleTokens = titre ? parseTitle(titre) : null;
---

<section
  id={id}
  class:list={['relative overflow-hidden', f.bg, f.text, padClass]}
>
  {blob && (
    <Blob
      size={320}
      color={f.blob}
      seed={id ? id.length % 5 : 1}
      opacity={0.35}
      class="pointer-events-none absolute -top-20 -right-20"
    />
  )}
  <div class="relative mx-auto max-w-310 px-6 md:px-10">
    {titleTokens && (
      <h2
        class="mb-10 max-w-[20ch] font-serif font-normal leading-[1.05] tracking-tight text-[36px] md:text-[48px]"
      >
        {titleTokens.map((token) =>
          token.type === 'em' ? (
            <em
              class:list={[
                'relative inline-block font-medium not-italic',
                accentColorClass[accent],
              ]}
            >
              <span class="italic">{token.text}</span>
              <HandUnderline
                color={accent}
                class="pointer-events-none absolute -bottom-2 left-0 right-0 w-full"
              />
            </em>
          ) : (
            <Fragment>{token.text}</Fragment>
          ),
        )}
      </h2>
    )}
    <slot />
  </div>
</section>
