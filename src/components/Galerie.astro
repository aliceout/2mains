---
// Mosaïque responsive 2/3/4 colonnes. Mode lightbox optionnel —
// modale accessible (Échap ferme, flèches naviguent, focus trap).
// Visuel refondu : radius 12px, légende mono petite italique.
import SmartImage from './SmartImage.astro';

type Image = {
  image: string;
  alt: string;
  legende?: string;
};

type Props = {
  images: Image[];
  colonnes?: 2 | 3 | 4;
  lightbox?: boolean;
};

const { images, colonnes = 3, lightbox = false } = Astro.props;

const colClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 md:grid-cols-3',
  4: 'sm:grid-cols-2 md:grid-cols-4',
}[colonnes];
---

<ul
  class:list={['grid gap-4', colClass]}
  data-galerie-lightbox={lightbox || undefined}
>
  {
    images.map((img, i) => (
      <li>
        <figure class="m-0">
          {lightbox ? (
            <button
              type="button"
              class="block w-full overflow-hidden rounded-xl border border-line transition-opacity hover:opacity-90"
              data-galerie-open={i}
              aria-label={`Ouvrir l'image : ${img.alt}`}
            >
              <SmartImage
                src={img.image}
                alt={img.alt}
                class="aspect-4/3 w-full"
              />
            </button>
          ) : (
            <a
              href={img.image}
              target="_blank"
              rel="noopener"
              class="block overflow-hidden rounded-xl border border-line transition-opacity hover:opacity-90"
              aria-label={`Ouvrir l'image en grand : ${img.alt}`}
            >
              <SmartImage
                src={img.image}
                alt={img.alt}
                class="aspect-4/3 w-full"
              />
            </a>
          )}
          {img.legende && (
            <figcaption
              class="mt-2 font-mono text-[11px] uppercase text-ink-3"
              style="letter-spacing: 0.06em;"
            >
              — {img.legende}
            </figcaption>
          )}
        </figure>
      </li>
    ))
  }
</ul>

{
  lightbox && (
    <div
      role="dialog"
      aria-modal="true"
      aria-label="Galerie d'images"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/90 p-4"
      data-galerie-modal
    >
      <button
        type="button"
        class="absolute top-4 right-4 rounded-full bg-paper/20 p-2 text-paper hover:bg-paper/30"
        aria-label="Fermer"
        data-galerie-close
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
      <button
        type="button"
        class="absolute left-4 top-1/2 -translate-y-1/2 rounded-full bg-paper/20 p-2 text-paper hover:bg-paper/30"
        aria-label="Image précédente"
        data-galerie-prev
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <button
        type="button"
        class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full bg-paper/20 p-2 text-paper hover:bg-paper/30"
        aria-label="Image suivante"
        data-galerie-next
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>
      <figure class="max-h-full max-w-full">
        <img
          src=""
          alt=""
          class="max-h-[85vh] max-w-[90vw] object-contain"
          data-galerie-img
        />
        <figcaption
          class="mt-3 text-center font-mono text-[11px] uppercase text-paper/80"
          style="letter-spacing: 0.06em;"
          data-galerie-caption
        />
      </figure>
    </div>
  )
}

{
  lightbox && (
    <script
      is:inline
      define:vars={{
        items: images.map((i) => ({
          src: i.image,
          alt: i.alt,
          legende: i.legende ?? '',
        })),
      }}
    >
      (function () {
        const modal = document.querySelector('[data-galerie-modal]');
        if (!modal) return;
        const img = modal.querySelector('[data-galerie-img]');
        const caption = modal.querySelector('[data-galerie-caption]');
        const openers = document.querySelectorAll('[data-galerie-open]');
        const closeBtn = modal.querySelector('[data-galerie-close]');
        const prevBtn = modal.querySelector('[data-galerie-prev]');
        const nextBtn = modal.querySelector('[data-galerie-next]');
        let current = 0;
        let lastFocus = null;

        function show(i) {
          current = (i + items.length) % items.length;
          const it = items[current];
          img.src = it.src;
          img.alt = it.alt;
          caption.textContent = it.legende ? '— ' + it.legende : '';
        }
        function open(i) {
          lastFocus = document.activeElement;
          show(i);
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          closeBtn.focus();
        }
        function close() {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          if (lastFocus) lastFocus.focus();
        }
        openers.forEach((b) => {
          b.addEventListener('click', () => open(Number(b.dataset.galerieOpen)));
        });
        closeBtn.addEventListener('click', close);
        prevBtn.addEventListener('click', () => show(current - 1));
        nextBtn.addEventListener('click', () => show(current + 1));
        modal.addEventListener('click', (e) => {
          if (e.target === modal) close();
        });
        document.addEventListener('keydown', (e) => {
          if (modal.classList.contains('hidden')) return;
          if (e.key === 'Escape') close();
          if (e.key === 'ArrowLeft') show(current - 1);
          if (e.key === 'ArrowRight') show(current + 1);
        });
      })();
    </script>
  )
}
