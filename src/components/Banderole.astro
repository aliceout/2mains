---
// Banderole en haut de page — pilotée par site.banderole_urgence.
// Bande pleine largeur sur fond orange/violet/rose selon la couleur,
// texte sans-serif simple. Rendu inline (sans <p>).
import { lexicalToHtmlInline } from '../lib/lexical';

type Props = {
  /** Message Lexical (richText). */
  message_rich?: unknown;
  couleur?: 'orange' | 'violet' | 'magenta';
};

const { message_rich, couleur = 'orange' } = Astro.props;

// magenta de l'ancienne API mappé sur rose dans la nouvelle palette.
const bg = {
  orange: 'bg-orange text-paper',
  violet: 'bg-violet text-paper',
  magenta: 'bg-rose text-ink',
}[couleur];

const html = lexicalToHtmlInline(message_rich);
---

<div
  role="region"
  aria-label="Annonce"
  class:list={['banderole px-6 py-3 text-center font-sans text-sm md:px-10', bg]}
>
  <p set:html={html} class="mx-auto max-w-4xl" />
</div>

<style>
  /* Style des liens dans la banderole (rendus par marked.parseInline).
     On hérite de la couleur du texte (paper sur fond orange/violet,
     ink sur fond rose) et on garde un soulignement marqué. */
  .banderole :global(a) {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }
  .banderole :global(a:hover) {
    text-decoration: none;
  }
</style>
