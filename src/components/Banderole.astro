---
// Banderole en haut de page — pilotée par site.banderole_urgence.
// Bande pleine largeur sur fond orange/violet/rose selon la couleur,
// texte sans-serif simple. Markdown inline minimal (gras / italique /
// liens) pour ne pas dépendre d'une lib lourde sur ce mini composant.
type Props = {
  message: string;
  couleur?: 'orange' | 'violet' | 'magenta';
};

const { message, couleur = 'orange' } = Astro.props;

// magenta de l'ancienne API mappé sur rose dans la nouvelle palette.
const bg = {
  orange: 'bg-orange text-paper',
  violet: 'bg-violet text-paper',
  magenta: 'bg-rose text-ink',
}[couleur];

function renderInline(md: string): string {
  let s = md
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
  s = s.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" class="underline decoration-2 underline-offset-2 hover:no-underline">$1</a>',
  );
  return s;
}
---

<div
  role="region"
  aria-label="Annonce"
  class:list={['px-6 py-3 text-center font-sans text-sm md:px-10', bg]}
>
  <p set:html={renderInline(message)} class="mx-auto max-w-4xl" />
</div>
