---
// Un chiffre énorme italique + texte explicatif. Inspiré du « 50 € »
// dans la page Entreprise du proto. Différent de BlocStat (grille).
import { marked } from 'marked';

type Couleur = 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu';

type Props = {
  chiffre: string;
  texte: string; // markdown
  source?: string;
  alignement?: 'gauche' | 'droite';
  couleur?: Couleur;
};

const {
  chiffre,
  texte,
  source,
  alignement = 'gauche',
  couleur = 'orange',
} = Astro.props;

const html = marked.parse(texte, { async: false }) as string;

const textCol: Record<Couleur, string> = {
  orange: 'text-orange',
  violet: 'text-violet',
  magenta: 'text-rose',
  vert: 'text-moss',
  bleu: 'text-mauve',
};
---

<div
  class:list={[
    'mx-auto grid max-w-275 items-center gap-12 md:grid-cols-[auto_1fr] md:gap-14',
    alignement === 'droite' && 'md:[&>*:first-child]:order-2',
  ]}
>
  <p
    class:list={[
      'font-serif italic font-medium leading-[0.85] tracking-[-0.04em] text-[96px] md:text-[160px]',
      textCol[couleur],
    ]}
  >
    {chiffre}
  </p>
  <div class="chiffre-text">
    <div
      class="font-serif text-[19px] font-normal leading-snug tracking-tight text-ink md:text-[22px]"
      set:html={html}
    />
    {source && (
      <p
        class="mt-4 font-mono text-[11px] uppercase text-ink-3"
        style="letter-spacing: 0.04em;"
      >
        — {source}
      </p>
    )}
  </div>
</div>

<style>
  .chiffre-text :global(p) {
    margin-bottom: 0.5rem;
  }
  .chiffre-text :global(p:last-child) {
    margin-bottom: 0;
  }
  .chiffre-text :global(strong) {
    font-weight: 500;
    color: var(--color-ink);
  }
  .chiffre-text :global(em) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    color: var(--color-orange);
  }
</style>
