---
type Carte = {
  titre: string;
  description: string;
  href?: string;
  cta?: string;
  couleur?: 'orange' | 'violet' | 'magenta' | 'vert' | 'bleu';
};

type Props = {
  cartes: Carte[];
  colonnes?: 2 | 3 | 4;
};

const { cartes, colonnes = 3 } = Astro.props;

const gridClass = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-2 lg:grid-cols-3',
  4: 'md:grid-cols-2 lg:grid-cols-4',
}[colonnes];

const accentMap = {
  orange: 'border-t-orange',
  violet: 'border-t-violet',
  magenta: 'border-t-magenta',
  vert: 'border-t-vert',
  bleu: 'border-t-bleu',
};
---

<div class:list={['grid gap-6', gridClass]}>
  {
    cartes.map((c) => (
      <article
        class:list={[
          'flex flex-col rounded-xl border-t-4 bg-paper p-6 shadow-sm transition-shadow hover:shadow-md',
          accentMap[c.couleur ?? 'orange'],
        ]}
      >
        <h3 class="mb-2 text-xl font-bold">{c.titre}</h3>
        <p class="mb-4 flex-1 text-sm leading-relaxed">{c.description}</p>
        {c.href && c.cta && (
          <a href={c.href} class="font-semibold text-orange hover:underline">
            {c.cta} →
          </a>
        )}
      </article>
    ))
  }
</div>
