---
// Mosaïque de témoignages — pioche dans la collection `temoignages`.
// Filtrage optionnel par contexte (participante / partenaire /
// professionnelle), limite par défaut 3, fond tinté tournant.
import type { LegacyEntry } from '../lib/payload';
import { renderRichOrMarkdown } from '../lib/lexical';

type Temoignage = LegacyEntry<{
  auteur: string;
  role?: string;
  contexte: string;
  /** Citation markdown legacy. */
  citation?: string;
  /** Citation Lexical (nouveau richText). Si rempli, écrase citation. */
  citation_rich?: unknown;
}>;

type Props = {
  temoignages: Temoignage[];
};

const { temoignages } = Astro.props;

// Couleurs tournantes : peach / honey / rose, pour 3 cartes.
type ToneKey = 'peach' | 'honey' | 'rose';
const tones: { bg: string; quote: string }[] = [
  { bg: 'bg-peach', quote: 'text-orange' },
  { bg: 'bg-honey', quote: 'text-orange' },
  { bg: 'bg-rose', quote: 'text-violet' },
];
---

<div class="grid gap-5 md:grid-cols-3">
  {
    temoignages.map((t, i) => {
      const tone = tones[i % tones.length];
      return (
        <article
          class:list={[
            'relative rounded-xl px-7 py-7',
            tone.bg,
          ]}
        >
          <span
            class:list={[
              'pointer-events-none mb-3 block font-serif italic font-medium leading-none',
              tone.quote,
            ]}
            aria-hidden="true"
            style="font-size: 44px;"
          >
            “
          </span>
          <blockquote
            class="font-serif italic text-[17px] leading-snug tracking-tight text-ink md:text-[18px]"
            set:html={renderRichOrMarkdown(t.data.citation_rich, t.data.citation, true)}
          />
          <cite class="mt-4 block font-mono text-[11px] uppercase not-italic text-ink-2" style="letter-spacing: 0.06em;">
            — {t.data.auteur}
            {t.data.role && <span class="opacity-80"> · {t.data.role}</span>}
          </cite>
        </article>
      );
    })
  }
</div>
