---
// Fil d'Ariane refondu sur le design handoff (Crumbs dans pages.jsx) :
// mono uppercase 12px letter-spacing 0.06em, séparateur slash en
// couleur line, dernier item en orange.
//
// Le BreadcrumbList JSON-LD est conservé pour le SEO.
import { getBreadcrumbs, getSiteSettings } from '../lib/site';

const settings = await getSiteSettings();
const crumbs = getBreadcrumbs(Astro.url.pathname);

const breadcrumbSchema =
  crumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: new URL(c.href, settings.url).toString(),
        })),
      }
    : null;
---

{
  breadcrumbSchema && (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  )
}
{
  crumbs.length > 0 && (
    <nav aria-label="Fil d'Ariane" class="border-b border-line bg-paper">
      <ol
        class="mx-auto flex max-w-310 flex-wrap items-center gap-2 px-6 py-3 font-mono text-[11px] uppercase text-ink-3 md:px-10"
        style="letter-spacing: 0.06em;"
      >
        {crumbs.map((c, i) => {
          const isLast = i === crumbs.length - 1;
          return (
            <li class="flex items-center gap-2">
              {i > 0 && (
                <span aria-hidden="true" class="text-line">
                  /
                </span>
              )}
              {isLast ? (
                <span aria-current="page" class="text-orange">
                  {c.label}
                </span>
              ) : (
                <a
                  href={c.href}
                  class="text-ink-3 transition-colors hover:text-orange"
                >
                  {c.label}
                </a>
              )}
            </li>
          );
        })}
      </ol>
    </nav>
  )
}
