---
import { getBreadcrumbs, getSiteSettings } from '../lib/site';

const settings = await getSiteSettings();
const crumbs = getBreadcrumbs(Astro.url.pathname);

const breadcrumbSchema =
  crumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: new URL(c.href, settings.url).toString(),
        })),
      }
    : null;
---

{
  breadcrumbSchema && (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  )
}
{
  crumbs.length > 0 && (
    <nav aria-label="Fil d'Ariane" class="border-b border-beige bg-paper">
      <ol class="mx-auto flex max-w-6xl flex-wrap items-center gap-1 px-4 py-2 text-sm text-ink/70">
        {crumbs.map((c, i) => {
          const isLast = i === crumbs.length - 1;
          return (
            <li class="flex items-center gap-1">
              {i > 0 && (
                <span aria-hidden="true" class="text-ink/40">
                  ›
                </span>
              )}
              {isLast ? (
                <span aria-current="page" class="font-semibold text-ink">
                  {c.label}
                </span>
              ) : (
                <a href={c.href} class="hover:text-orange hover:underline">
                  {c.label}
                </a>
              )}
            </li>
          );
        })}
      </ol>
    </nav>
  )
}
