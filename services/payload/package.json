{
  "name": "2mains-payload",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "dotenv -e ../../.env -- cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "lint": "next lint",
    "generate:types": "dotenv -e ../../.env -- cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "migrate": "dotenv -e ../../.env -- cross-env NODE_OPTIONS=--no-deprecation payload migrate"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.32.0",
    "@payloadcms/next": "^3.32.0",
    "@payloadcms/richtext-lexical": "^3.32.0",
    "@payloadcms/ui": "^3.32.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.9.0",
    "next": "^15.2.0",
    "payload": "^3.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
