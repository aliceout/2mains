# Service Payload — variables d'environnement (template).
# En dev local, copie dans `.env` (à la racine de services/payload/)
# avec les valeurs du Postgres dev (cf docker-compose.dev.yml racine).
# En prod, ces vars viennent du `.env` racine via `docker compose
# --env-file ../../.env` — pas besoin de remplir ce fichier.

# ─── DB Postgres ──────────────────────────────────────────────
# Soit DATABASE_URI complet, soit composé via les vars POSTGRES_*.
DATABASE_URI=postgres://payload:payload@localhost:5432/payload

# ─── Auth / sessions ──────────────────────────────────────────
# Random 64 chars hex. En dev tu peux mettre n'importe quoi.
PAYLOAD_SECRET=dev-only-secret-do-not-use-in-prod

# ─── URL publique du serveur (pour les liens absolus admin) ──
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
