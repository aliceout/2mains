# ─────────────────────────────────────────────────────────────────
# Variables d'environnement pour 2mains de femmes
#
# Ce fichier est un TEMPLATE versionné. Il liste les clés attendues
# par la stack (Astro + Payload + Postgres + Mail).
#
# Archi Infisical (Cloud) :
#   /services/2mains/             → vars communes (ADDRESS, PORT_*, ...)
#   /services/2mains/payload/     → PAYLOAD_SECRET, PAYLOAD_INTERNAL_URL
#   /services/2mains/postgres/    → POSTGRES_USER/PASSWORD/DB
#   /services/2mains/smtp/        → SMTP_*, MAIL_TO
#   /services/2mains/web/         → RATE_LIMIT_PER_HOUR, ALLOWED_ORIGIN
#
# En prod : généré automatiquement par scripts/deploy.sh via
#   `infisical export --env=prod --path=/services/2mains --recursive
#    --format=dotenv > .env`
# En dev  : tu fetches l'env "dev" via Dev Setup (VS Code) ou en CLI :
#   `infisical export --env=dev --path=/services/2mains --recursive
#    --format=dotenv > .env`
#
# Le `.env` réel est gitignored (cf .gitignore). Ne commit JAMAIS de
# valeurs en clair.
# ─────────────────────────────────────────────────────────────────


# ─── Ports d'exposition côté host (compose.yml) ──────────────────
# Path Infisical : /services/2mains (racine, vars communes)
# Les containers écoutent toujours sur leurs ports internes (payload
# 3001, site 4321, mail 3000), mais le mapping côté host est piloté
# par ces vars pour rester aligné avec la config nginx du VPS.
# Convention historique : 8066 / 8064 / 8065.
PORT_PAYLOAD=8066
PORT_SITE=8064
PORT_MAIL=8065


# ─── Postgres (interne docker, jamais exposé sur le host) ────────
# Path Infisical : /services/2mains/postgres
POSTGRES_USER=payload
POSTGRES_PASSWORD=
POSTGRES_DB=payload


# ─── URL publique du site ────────────────────────────────────────
# Path Infisical : /services/2mains (racine, vars communes)
# Domaine racine SANS /cms ni trailing slash. Source de vérité unique
# pour :
#   - Astro (champ `site:` de astro.config.mjs → sitemap, RSS, JSON-LD)
#   - Payload (`serverURL` + cors/csrf + mails d'invitation/OTP/OG)
#   - iCal (URLs des feeds + UID des événements, host extrait)
# Lue à la fois au build (Astro) et au runtime (Payload, SSR Astro).
ADDRESS=https://example.com


# ─── Payload CMS (admin + API sous /cms/*) ───────────────────────
# Path Infisical : /services/2mains/payload
# PAYLOAD_SECRET : random 64+ chars, généré une fois
#   (ex: openssl rand -hex 32)
# PAYLOAD_INTERNAL_URL : URL interne docker, utilisée par Astro
#   server-side pour fetcher Payload sans passer par internet
PAYLOAD_SECRET=
PAYLOAD_INTERNAL_URL=http://payload:3001


# ─── Mail backend (formulaire de contact + auth Payload) ─────────
# Path Infisical : /services/2mains/smtp
# Les vars SMTP_* sont partagées entre le service contact-mail
# (formulaire public) et Payload (mails d'invitation, OTP 2FA,
# notifications de sécurité). Le nom affiché dans le From: est
# hardcodé côté code (cf. services/payload/src/auth/transport.ts).
#
# Ces valeurs ne servent qu'en prod. En dev local, `pnpm dev:api` et
# `pnpm dev:mail` overrident automatiquement ces vars pour pointer sur
# Mailpit (UI http://localhost:8025) — tu n'as rien à toucher ici.
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=contact@example.com
MAIL_TO=contact@example.com


# Path Infisical : /services/2mains/web
RATE_LIMIT_PER_HOUR=10
ALLOWED_ORIGIN=https://example.com


# ─── Auth (invitations + 2FA + sessions) ─────────────────────────
# Path Infisical : /services/2mains/payload
# Toutes optionnelles, valeurs par défaut entre parenthèses.
# INVITATION_TTL_DAYS       — durée de validité du lien d'invitation (7)
# OTP_TTL_MINUTES           — durée de validité d'un code OTP email (10)
# TRUSTED_DEVICE_TTL_DAYS   — durée d'un appareil de confiance après 2FA (7)
# SESSION_INACTIVE_HOURS    — logout auto après cette durée d'inactivité (48)
# PAYLOAD_INSECURE_COOKIES  — mettre "true" UNIQUEMENT pour debug HTTP en dev
INVITATION_TTL_DAYS=7
OTP_TTL_MINUTES=10
TRUSTED_DEVICE_TTL_DAYS=7
SESSION_INACTIVE_HOURS=48
